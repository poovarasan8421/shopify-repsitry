          "type": "faq",
          "settings": {
            "ques": "How do I take care of my Lafoli products?",
            "ans": "A little love goes a long way in keeping your Lafoli looking its best! When not in use, store it in the provided Lafoli dust bag. After a day out, wipe gently with a soft, dry cloth."
          }
        },
        "faq_PpdWrC": {
          "type": "faq",
          "settings": {
