    "double_image_content_AiqQV6": {
      "type": "double-image-content",
      "disabled": true,
      "name": "Double Image Content",
      "settings": {
        "section-heading": "who <br><span>we are</span>",
        "left-image-desk": "shopify://shop_images/image_261_0727b901-d02e-4321-b973-d208f7ce2d39.png",
        "left-image-mob": "shopify://shop_images/image_261_1d95de24-6952-48c8-b355-a5451b852205.png",
        "right-first-content": "Wake up. Brush your teeth. Walk in a straight line. Do the smart thing.\nThat’s what we’re taught, isn’t it? To stay within the lines, take permission, and always play by the book.\n But the truth is, sanity never started a good story.",
        "right-second-content": "For us, bags are a canvas to explore  this madness. All our products are designed to have a unique edge to them. Just like you do.<br> <br>  Let us be a reminder to choose the unexpected. To go a little mad sometimes. To step off the path, stay out too late, laugh too loudly. Don't wait, seize.\nBecause that’s when the magic happens. When ordinary becomes extraordinary.<br>\n<br>Life gets a lot more fun off-script.\n<br>Always own your madness.",
        "right-image-desk": "shopify://shop_images/Vector_6ea4d276-e2d0-401e-a1fb-569bda1eaf05.png",
