<div class="spacing-style section-{{ section.id }}-padding" style="background: {{ section.settings.bg__clr }};">
  <div class="double__image_content">
    <div class="double__image_container">
      {% if section.settings['desk-img'] != blank or section.settings['mob-img'] != blank %}
        <div class="image__box">
          <div class="image__block">
            {% if section.settings['desk-img'] != blank %}
              {{
                section.settings['desk-img']
                | image_url: width: section.settings['desk-img'].width
                | image_tag:
                  widths: '400, 600, 700, 800, 1000, 1400, 1800, 2000',
                  sizes: '(min-width: 769px) 20vw',
                  class: 'cust_bg_img desktop-img',
                  alt: 'Banner image'
                
              }}
            {% endif %}

            {% if section.settings['mob-img'] != blank %}
              {{
                section.settings['mob-img']
                | image_url: width: section.settings['mob-img'].width
                | image_tag:
                  widths: '320, 480, 500, 640, 800, 1000, 1200',
                  sizes: '(max-width: 768px) 50vw',
                  class: 'cust_bg_img mobile-img',
                  alt: 'Banner image'
                  
              }}
            {% endif %}
          </div>
        </div>
      {% endif %}

      <div class="contnt__box">
        {% assign faq_items = product.metafields.custom.faq_lists.value %}
        <div class="contnt__inner">
          {% if section.settings['main-head'] != blank %}
            <h2 class="heading">{{ section.settings['main-head'] }}</h2>
          {% endif %}
          <div class="accordion">
            {% comment %} {% for faq in faq_items %} {% endcomment %}
            {% for block in section.blocks %}
              {% if block.settings.ques != blank %}
                <div class="accordion-item">
                  <button
                    class="accord_btn"
                    id="accordion-button-{{ forloop.index }}"
                    aria-expanded="false"
                    aria-controls="accordion-content-{{ forloop.index }}"
                  >
                    <span class="accordion-title">
                      {{- block.settings.ques }}
                      <span class="svg-wrapper icon-plus">
                        {{- 'plus.svg' | inline_asset_content -}}
                      </span>
                      <span class="svg-wrapper icon-minus">
                        {{- 'minus.svg' | inline_asset_content -}}
                      </span>
                    </span>

                    <span class="icon" aria-hidden="true"></span>
                  </button>

                  <div
                    id="accordion-content-{{ forloop.index }}"
                    class="accordion-content"
                    hidden
                  >
                    <p>{{ block.settings.ans }}</p>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="policy-box">
          {% for i in (1..4) %}
            {% capture img_id %}img{{ i }}{% endcapture %}
            {% capture text_id %}text{{ i }}{% endcapture %}

            {% assign image = section.settings[img_id] %}
            {% assign text = section.settings[text_id] %}
            {% if image != blank %}
              <div class="policy-box-inner">
                <div class="policy-image">
                  {% if image != blank %}
                    {{
                      image
                      | image_url: width: 600
                      | image_tag: width: image.width, height: image.height, class: 'cust_bg_img', alt: 'trust image'
                    }}
                  {% endif %}
                </div>
                <div class="policy-heading">
                  {% if text != blank %}
                    <p>{{ text }}</p>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  {% comment %} const items = document.querySelectorAll('#shopify-section-{{ section.id }} .accordion button');
  console.log(items , "itemsitems")
  function toggleAccordion() {
    const itemToggle = this.getAttribute('aria-expanded');

    for (i = 0; i < items.length; i++) {
      items[i].setAttribute('aria-expanded', 'false');
    }

    if (itemToggle == 'false') {
      this.setAttribute('aria-expanded', 'true');
    }
  }

  items.forEach((item) => item.addEventListener('click', toggleAccordion)); {% endcomment %}

  document.addEventListener("DOMContentLoaded", () => {
    const accordions = document.querySelectorAll('#shopify-section-{{ section.id }} .accordion .accord_btn');

    accordions.forEach((btn) => {
      const content = document.getElementById(btn.getAttribute("aria-controls"));

      btn.addEventListener("click", () => {
        const isExpanded = btn.getAttribute("aria-expanded") === "true";

        // Close all accordions first
        accordions.forEach((item) => {
          const c = document.getElementById(item.getAttribute("aria-controls"));
          item.setAttribute("aria-expanded", "false");
          c.style.maxHeight = null;
          c.hidden = true;
        });

        // If this one was closed, open it
        if (!isExpanded) {
          btn.setAttribute("aria-expanded", "true");

          // 🔹 Must unhide before calculating scrollHeight
          content.hidden = false;
          content.style.maxHeight = content.scrollHeight + "px";
        }
      });
    });
  });
</script>

<style>
  .section-{{ section.id }}-padding {
      margin-top: {{ section.settings.desktop-padding-top }}px;
      margin-bottom: {{ section.settings.desktop-padding-bottom }}px;
      position: relative;
      {% comment %} z-index: 1; {% endcomment %}
  }
  #shopify-section-{{ section.id }} .double__image_content{
    max-width:100%;
    {% comment %} margin:0 auto; {% endcomment %}
  }
  #shopify-section-{{ section.id }} .double__image_container {
      display: flex;
      flex-wrap: wrap;

      {% if section.settings.enable-cover-image %}

      {% else %}
      align-items: center;
      {% endif %}
  }
  #shopify-section-{{ section.id }} .double__image_container .image__box {
      display: flex;
      width: 47%;
      line-height: 0;
      {% comment %} padding-left:2rem; {% endcomment %}
  }
   #shopify-section-{{ section.id }} .double__image_container .image__box .image__block{
      width:100%;
  }
  #shopify-section-{{ section.id }} .double__image_container .contnt__box {
      width: 50%;
      display: flex;
      flex-direction: column;
      justify-content: center;
  }
  #shopify-section-{{ section.id }} .image__box .banner__img {
      width: 50%;
      line-height: 0;
  }
  #shopify-section-{{ section.id }} img {
      width: 100%;
      height: 100%;
      {% comment %} object-fit: cover;
      object-position: center center; {% endcomment %}
  }
  #shopify-section-{{ section.id }} .contnt__box .contnt__inner {
      {% comment %} width: 550px; {% endcomment %}
      width:650px;
      max-width: 100%;
      margin:0 auto;
      padding: 30px 30px;
      text-align: {{ section.settings.text-align }};
  }
  #shopify-section-{{ section.id }} .heading {
      font-size: 24px;
      line-height: 24px;
      letter-spacing: 1px;
      margin: 0 0 15px;
      text-transform: uppercase;
      color: {{ section.settings.heading__clr }};
  }

  {% comment %} #shopify-section-{{ section.id }} .accordion button[aria-expanded='true'] + .accordion-content {
    display: block;
    max-height: 9em;
    transition: all 200ms linear;
    will-change: opacity, max-height;
  } {% endcomment %}

  {% comment %} #shopify-section-{{ section.id }} .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  } {% endcomment %}
  #shopify-section-{{ section.id }} .accordion .accordion-content {
    {% comment %} display: none; {% endcomment %}
    max-height: 0;
    overflow: hidden;
    transition: opacity 200ms linear, max-height 200ms linear;
    will-change: opacity, max-height;
    padding: 0 0 17px;
  }
  #shopify-section-{{ section.id }} .accordion-item {
      border-bottom: 1px solid #e3e3e3;
  }
  #shopify-section-{{ section.id }} .accordion-item:first-child {
      border-top: 1px solid #e3e3e3;
  }
  #shopify-section-{{ section.id }} .accordion-item .accord_btn {
      border: none;
      padding: 17px 0;
      width: 100%;
      text-align: left;
      background: transparent;
      position: relative;
  }
  {% comment %} #shopify-section-{{ section.id }} .accordion button .icon::before {
      display: block;
      position: absolute;
      content: '';
      top: 25px;
      right: 5px;
      width: 16px;
      height: 1.5px;
      background: #000000;
  }
  #shopify-section-{{ section.id }} .accordion button .icon::after {
      display: block;
      position: absolute;
      content: '';
      top: 18px;
      right: 13px;
      width: 1.5px;
      height: 16px;
      background: #000000;
  } {% endcomment %}
  #shopify-section-{{ section.id }} .accordion button[aria-expanded='true'] .icon::after {
      width: 0;
  }
  #shopify-section-{{ section.id }} .accordion-title {
      font-size: 14px;
      line-height: 18px;
      letter-spacing: 1px;
      font-family: var(--font-paragraph--family);
      font-weight: 400;
      color: {{ section.settings.acc_text__clr }};
      display:flex;
      align-items:center;
      justify-content:space-between;
  }
  #shopify-section-{{ section.id }} .accordion-title .svg-wrapper.icon-minus{
      display:none;
  }
  #shopify-section-{{ section.id }} .accord_btn[aria-expanded="true"] .icon-minus {
    display: inline-flex;
  }
  #shopify-section-{{ section.id }} .accord_btn[aria-expanded="true"] .icon-plus {
    display: none;
  }
  #shopify-section-{{ section.id }} .accordion-content {
      font-size: 12px;
      line-height: 16px;
      letter-spacing: 1px;
      font-family: var(--font-paragraph--family);
      font-weight: 400;
      color: {{ section.settings.acc_cnt__clr }};
  }
  #shopify-section-{{ section.id }} .policy-box-inner{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
  }
  {% comment %} #shopify-section-{{ section.id }} .policy-image {

      margin: 0 auto;
      align-items: center;
      display: flex;

  } {% endcomment %}
  #shopify-section-{{ section.id }} .policy-image img{
      width: 35px;
  }
  #shopify-section-{{ section.id }} .policy-box {
    padding: 30px 30px;
    display: flex;
    gap: 50px;
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .policy-heading {
      padding-top: 20px;
      font-size: 18px;
      line-height: 22px;
      font-weight: 400;
      letter-spacing:0.05em;
      text-transform: uppercase;
      align-items: center;
      text-align: center;
      font-family:'Outfit'
  }
  @media only screen and (max-width: 999px) {
  #shopify-section-{{ section.id }} .contnt__box .contnt__inner {
    padding: 0px 30px 30px 30px;
  }
  }

  @media only screen and (max-width: 750px) {
  .section-{{ section.id }}-padding {
    margin-top: {{ section.settings.mobile-padding-top }}px;
    margin-bottom: {{ section.settings.mobile-padding-bottom }}px;
    padding: 0;
  }
  #shopify-section-{{ section.id }} .double__image_content{
    max-width:100%;
  }
  #shopify-section-{{ section.id }} .policy-box-inner{
    width:33%;
  }

  #shopify-section-{{ section.id }} .section{
    --full-page-grid-with-margins:0;
  }
  --full-page-grid-with-margins
  #shopify-section-{{ section.id }} .double__image_container {
     max-width:100%;
  }
  #shopify-section-{{ section.id }} .section__container {
      grid-template-columns: unset;
  }
  #shopify-section-{{ section.id }} .double__image_container .image__box {
    padding-left:0;
  }
  #shopify-section-{{ section.id }} .double__image_container .image__box,
  #shopify-section-{{ section.id }} .double__image_container .contnt__box {
      width: 100%;
  }
  #shopify-section-{{ section.id }} .contnt__box .contnt__inner {
      width: 100%;
      max-width: 100%;
      padding: 16px 20px 24px;
  }
  #shopify-section-{{ section.id }} .heading {
      font-size: 14px;
      line-height: 16px;
      margin: 0 0 15px;
      padding:0;
  }
  #shopify-section-{{ section.id }} .desktop-img {
      display: none;
  }
  #shopify-section-{{ section.id }} .accordion-item .accord_btn {
      padding: 15px 0;
  }
  #shopify-section-{{ section.id }} .accordion-title {
      font-size: 12px;
      line-height: 16px;
  }
  #shopify-section-{{ section.id }} .policy-heading {
    font-size: 14px;
    line-height: 16px;
    padding-top:15px;
  }
  #shopify-section-{{ section.id }} .policy-heading br {
      display: none;
  }
  #shopify-section-{{ section.id }} .policy-box {
    gap: 45px 185px;
    padding: 14px 15px 24px;
  }
  }
  @media screen and (max-width: 570px) {
  #shopify-section-{{ section.id }} .policy-box {
    gap: 45px 109px;
  }

  }
  @media screen and (max-width: 400px) {
  #shopify-section-{{ section.id }} .policy-box {
    gap: 45px 50px;
  }
  }
  @media screen and (max-width: 375px) {
  #shopify-section-{{ section.id }} .policy-box {
    gap: 35px 27px;
    padding: 14px 15px 24px;
  }
  #shopify-section-{{ section.id }} .policy-box-inner{
    width:45%;
  }
  }
  @media screen and (min-width: 750px) {
  #shopify-section-{{ section.id }} .mobile-img {
      display: none;
  }
  }
  @media screen and (min-width: 905px) and (max-width: 1196px){
  #shopify-section-{{ section.id }} .policy-heading {
    font-size: 12px;
    line-height: 15px;
  }
  #shopify-section-{{ section.id }} .policy-box {
    padding: 18px 18px;
    gap: 40px;
  }
  }
  @media screen and (min-width: 751px) and (max-width: 904px){
  #shopify-section-{{ section.id }} .policy-box {
      padding: 0px 10px;
      gap: 24px;
  }
  #shopify-section-{{ section.id }} .heading {
      margin: 0px;
  }
  #shopify-section-{{ section.id }} .contnt__box {
    padding: 25px 0px;
  }
  #shopify-section-{{ section.id }} .contnt__box .contnt__inner {
    padding: 0px 30px 30px 30px;
  }
  #shopify-section-{{ section.id }} .policy-heading {
    font-size: 12px;
    line-height: 15px;
  }
  }
</style>
{% schema %}
{
  "name": "Policy faq",

  "settings": [
    {
      "type": "checkbox",
      "id": "enable-cover-image",
      "label": "Enable Cover Image"
    },
    {
      "type": "text",
      "id": "main-head",
      "label": "section heading"
    },
    {
      "type": "image_picker",
      "id": "desk-img",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mob-img",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Content Alignment"
    },

    {
      "type": "select",
      "id": "text-align",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Text Alignment"
    },
    {
      "type": "header",
      "content": "Section Colour"
    },
    {
      "type": "color",
      "id": "bg__clr",
      "label": "Background Colour"
    },
    {
      "type": "color",
      "id": "heading__clr",
      "label": "Heading Colour",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "acc_text__clr",
      "label": "Accordion Heading Colour",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "acc_cnt__clr",
      "label": "Accordion Content Colour",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Trust image"
    },
    {
      "type": "image_picker",
      "id": "img1",
      "label": "Image 1"
    },
    {
      "type": "textarea",
      "id": "text1",
      "label": "Text"
    },
    {
      "type": "image_picker",
      "id": "img2",
      "label": "Image 2"
    },
    {
      "type": "textarea",
      "id": "text2",
      "label": "Text"
    },
    {
      "type": "image_picker",
      "id": "img3",
      "label": "Image 3"
    },
    {
      "type": "textarea",
      "id": "text3",
      "label": "Text"
    },
    {
      "type": "image_picker",
      "id": "img4",
      "label": "Image 4"
    },
    {
      "type": "textarea",
      "id": "text4",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Desktop Section Padding"
    },

    {
      "type": "range",
      "id": "desktop-padding-top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop-padding-bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Section Padding"
    },
    {
      "type": "range",
      "id": "mobile-padding-top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile-padding-bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    }
  ],
