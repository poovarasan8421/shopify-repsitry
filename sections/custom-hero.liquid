{% assign overlay_opacity = section.settings.gradient_overlay_opacity | times: 0.01 %}
{% assign overlay_color = section.settings.gradient_overlay_color | color_to_rgb | remove: 'rgb(' | remove: ')' | split: ',' %}
{% assign r = overlay_color[0] | strip %}
{% assign g = overlay_color[1] | strip %}
{% assign b = overlay_color[2] | strip %}
<section
  class="custom-image-banner 
    direction-{{ section.settings.direction }}
    alignment-{{ section.settings.alignment }} 
    position-{{ section.settings.position }}
    {% if section.settings.direction == 'horizontal' and section.settings.position == 'space-between' %}space-between-{{ section.settings.space_between_alignment }}{% endif %}
      mob_direction-{{ section.settings.mobile_direction }}
    mob_alignment-{{ section.settings.mobile_alignment }} 
    mob_position-{{ section.settings.mobile_position }}
      {% if section.settings.mobile_direction == 'horizontal' and section.settings.mobile_position == 'space-between' %}mob_space-between-{{ section.settings.mobile_position_space_between_alignment }}{% endif %}
    color-scheme-{{ section.settings.color_scheme }}"
  style="padding-top: {{ section.settings.padding_top }}px; 
         padding-bottom: {{ section.settings.padding_bottom }}px;"
>

  <div class="image-banner-wrapper">
    <div class="image-banner-media">

      {% assign widths = '200, 400, 600, 800, 900, 1200, 1600, 1800, 2000' %}

      <picture>
        {% if section.settings.image_mobile %}
          <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 750 }}">
        {% endif %}

        {% if section.settings.image_desktop %}
          {{ section.settings.image_desktop
            | image_url: width: 2000
            | image_tag:
              width: section.settings.image_desktop.width,
              height: section.settings.image_desktop.height,
              class: 'image-fill',
              sizes: '(max-width: 749px) 100vw, 50vw',
              widths: widths,
              alt: 'Hero Banner Image'
          }}
        {% endif %}
      </picture>

      <div class="image-banner-overlay" style="
        gap: {{ section.settings.gap | default: 20 }}px;
        padding-top: {{ section.settings.overlay_padding_top }}px;
        padding-bottom: {{ section.settings.overlay_padding_bottom }}px;
        background: linear-gradient(to top, rgba({{ r }}, {{ g }}, {{ b }}, {{ overlay_opacity }}), rgba({{ r }}, {{ g }}, {{ b }}, 0), transparent);
      ">
        {% if section.settings.heading != blank %}
          <h2 class="image-banner-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text1 != blank %}
          <p class="image-banner-text">{{ section.settings.text1 }}</p>
        {% endif %}
        {% if section.settings.subtext != blank and section.settings.subtext_link != blank %}
          <a href="{{ section.settings.subtext_link }}" class="image-banner-subtext underline" {% if section.settings.open_new_tab %}target="_blank"{% endif %}>
            {{ section.settings.subtext }}
          </a>
        {% elsif section.settings.subtext != blank %}
          <div class="image-banner-subtext">{{ section.settings.subtext }}</div>
        {% endif %}
        {% if section.settings.button_text != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}"
             class="image-banner-button"
             {% if section.settings.button_new_tab %}target="_blank"{% endif %}>
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<style>
#shopify-section-{{ section.id }} .custom-image-banner {
  position: relative;
  font-family: 'Outfit', sans-serif;
}

#shopify-section-{{ section.id }} .image-banner-wrapper {
  position: relative;
}

#shopify-section-{{ section.id }} .image-fill {
  width: 100%;
  height: auto;
  display: block;
}

#shopify-section-{{ section.id }} .image-banner-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  color: white;
  text-align: center;
  box-sizing: border-box;
}

/* Direction */
#shopify-section-{{ section.id }} .direction-vertical .image-banner-overlay { flex-direction: column; }
#shopify-section-{{ section.id }} .direction-horizontal .image-banner-overlay { flex-direction: row; }

/* Horizontal Alignment */
#shopify-section-{{ section.id }} .direction-horizontal.alignment-left .image-banner-overlay { justify-content: flex-start; text-align: left; }
#shopify-section-{{ section.id }} .direction-horizontal.alignment-center .image-banner-overlay { justify-content: center; text-align: center; }
#shopify-section-{{ section.id }} .direction-horizontal.alignment-right .image-banner-overlay { justify-content: flex-end; text-align: right; }

/* Vertical Position */
#shopify-section-{{ section.id }} .direction-horizontal.position-top .image-banner-overlay { align-items: flex-start; }
#shopify-section-{{ section.id }} .direction-horizontal.position-center .image-banner-overlay { align-items: center; }
#shopify-section-{{ section.id }} .direction-horizontal.position-bottom .image-banner-overlay { align-items: flex-end; }
#shopify-section-{{ section.id }} .direction-horizontal.position-space-between .image-banner-overlay { justify-content: space-between; align-items: flex-end; }

#shopify-section-{{ section.id }} .direction-vertical.alignment-left .image-banner-overlay { align-items: flex-start; text-align: left; }
#shopify-section-{{ section.id }} .direction-vertical.alignment-center .image-banner-overlay { align-items: center; text-align: center; }
#shopify-section-{{ section.id }} .direction-vertical.alignment-right .image-banner-overlay { align-items: flex-end; text-align: right; }

#shopify-section-{{ section.id }} .direction-vertical.position-top .image-banner-overlay { justify-content: flex-start; }
#shopify-section-{{ section.id }} .direction-vertical.position-center .image-banner-overlay { justify-content: center; }
#shopify-section-{{ section.id }} .direction-vertical.position-bottom .image-banner-overlay { justify-content: flex-end; }
#shopify-section-{{ section.id }} .direction-vertical.position-space-between .image-banner-overlay { justify-content: space-between; }

#shopify-section-{{ section.id }} .image-banner-heading { font-size: 20px; margin: 0; font-weight: 500; line-height: 22px; letter-spacing: 0.05em; padding-bottom: 10px; }
#shopify-section-{{ section.id }} .image-banner-subtext { font-size: 12px; margin-top: 5px; }
#shopify-section-{{ section.id }} .underline { color: white; text-decoration: underline; }
#shopify-section-{{ section.id }} p.image-banner-text { max-width: 250px; font-size: 12px; line-height: 14px; letter-spacing: 0.5px; font-weight: 300; color: #EFEDE4; margin: 5px; font-family:'Helvetica-Neue' }
#shopify-section-{{ section.id }} .image-banner-button { 
    border: none;
    {% comment %} text-decoration: underline; {% endcomment %}
     text-decoration:none;
    font-family: 'Outfit';
    font-weight: 500;
    font-size: 14px;
    line-height: 16px;
    letter-spacing: 0.05em;
    {% comment %} color: #FFFFFF;
    background:#000; {% endcomment %}
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    padding:10px;
    margin-bottom: 25px;
   }

/* Responsive */
@media screen and (max-width: 749px) {
  #shopify-section-{{ section.id }} .image-banner-heading { font-size: 18px; padding-bottom: 8px; line-height: 20px; }
  #shopify-section-{{ section.id }} .image-banner-subtext { font-size: 10px; margin-top: 5px; }
  #shopify-section-{{ section.id }} .custom-image-banner { padding-top: {{ section.settings.mobile_padding_top }}px !important; padding-bottom: {{ section.settings.mobile_padding_bottom }}px !important; }
  #shopify-section-{{ section.id }} .image-banner-button { padding: 12px 25px; font-size: 12px; line-height: 16px; margin-bottom:30px;}
  #shopify-section-{{ section.id }} .image-banner-overlay { 
    padding-bottom: {{ section.settings.overlay_padding_bottom_mobile }}px !important;
    gap:{{section.settings.mobile_gap }}px !important;
  }

#shopify-section-{{ section.id }} p.image-banner-text { 
   font-size: 10px;
   line-height: 14px;
   }
   /* Direction */
#shopify-section-{{ section.id }} .mob_direction-vertical .image-banner-overlay { flex-direction: column; }
#shopify-section-{{ section.id }} .mob_direction-horizontal .image-banner-overlay { flex-direction: row; }

/* Horizontal Alignment */
#shopify-section-{{ section.id }} .mob_direction-horizontal.mob_alignment-left .image-banner-overlay { justify-content: flex-start; text-align: left; }
#shopify-section-{{ section.id }} .mob_direction-horizontal.mob_alignment-center .image-banner-overlay { justify-content: center; text-align: center; }
#shopify-section-{{ section.id }} .mob_direction-horizontal.mob_alignment-right .image-banner-overlay { justify-content: flex-end; text-align: right; }

/* Vertical Position */
#shopify-section-{{ section.id }} .mob_direction-horizontal.mob_position-top .image-banner-overlay { align-items: flex-start; }
#shopify-section-{{ section.id }} .mob_direction-horizontal.mob_position-center .image-banner-overlay { align-items: center; }
#shopify-section-{{ section.id }} .mob_direction-horizontal.mob_position-bottom .image-banner-overlay { align-items: flex-end; }
#shopify-section-{{ section.id }} .mob_direction-horizontal.mob_position-space-between .image-banner-overlay { justify-content: space-between; align-items: flex-end; }

#shopify-section-{{ section.id }} .mob_direction-vertical.mob_alignment-left .image-banner-overlay { align-items: flex-start; text-align: left; }
#shopify-section-{{ section.id }} .mob_direction-vertical.mob_alignment-center .image-banner-overlay { align-items: center; text-align: center; }
#shopify-section-{{ section.id }} .mob_direction-vertical.mob_alignment-right .image-banner-overlay { align-items: flex-end; text-align: right; }

#shopify-section-{{ section.id }} .mob_direction-vertical.mob_position-top .image-banner-overlay { justify-content: flex-start; }
#shopify-section-{{ section.id }} .mob_direction-vertical.mob_position-center .image-banner-overlay { justify-content: center; }
#shopify-section-{{ section.id }} .mob_direction-vertical.mob_position-bottom .image-banner-overlay { justify-content: flex-end; }
#shopify-section-{{ section.id }} .mob_direction-vertical.mob_position-space-between .image-banner-overlay { justify-content: space-between; }

</style>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    { "type": "header", "content": "Overlay Padding" },
    { "type": "range", "id": "overlay_padding_bottom", "label": "Bottom (Desktop)", "min":0, "max":200, "step":5, "default":25 },
    { "type": "range", "id": "overlay_padding_bottom_mobile", "label": "Bottom (Mobile)", "min":0, "max":200, "step":5, "default":15 },
    { "type": "color", "id": "gradient_overlay_color", "label": "Gradient Overlay Color", "default": "#000000" },
    { "type": "range", "id": "gradient_overlay_opacity", "label": "Overlay Opacity (%)", "min":0, "max":100, "step":1, "default":45 },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image_desktop", "label": "Desktop Image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile Image" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "“NEW COLLECTION”" },
    { "type":"text","id":"text1", "label":"Text" },
    { "type":"text","id":"button_text","label":"Button Text","default":"DISCOVER NOW" },
    { "type":"url","id":"button_link","label":"Button Link" },
    { "type":"checkbox","id":"button_new_tab","label":"Open button link in new tab","default":false },
    { "type":"color","id":"button_background","label":"Button Background Color","default":"#000000" },
    { "type":"color","id":"button_text_color","label":"Button Text Color","default":"#ffffff" },
    { "type":"url","id":"subtext_link","label":"Subtext Link" },
    { "type":"checkbox","id":"open_new_tab","label":"Open link in new tab","default":false },
    { "type":"header","content":"Layout" },
    { "type":"select","id":"direction","label":"Direction","default":"vertical","options":[{"value":"vertical","label":"Vertical"},{"value":"horizontal","label":"Horizontal"}]},
    { "type":"select","id":"alignment","label":"Alignment","default":"center","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}]},
    { "type":"select","id":"position","label":"Position","default":"center","options":[{"value":"top","label":"Top"},{"value":"center","label":"Center"},{"value":"bottom","label":"Bottom"},{"value":"space-between","label":"Space between"}]},
    { "type":"select","id":"space_between_alignment","label":"Space Between","default":"center","options":[{"value":"top","label":"Top"},{"value":"center","label":"Center"},{"value":"bottom","label":"Bottom"}]},
    { "type":"range","id":"gap","min":0,"max":100,"step":1,"unit":"px","label":"Gap","default":16 },
     { "type":"header","content":"Mobile Layout" },
    { "type":"select","id":"mobile_direction","label":"Direction","default":"vertical","options":[{"value":"vertical","label":"Vertical"},{"value":"horizontal","label":"Horizontal"}]},
    { "type":"select","id":"mobile_alignment","label":"Alignment","default":"center","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}]},
    { "type":"select","id":"mobile_position","label":"Position","default":"center","options":[{"value":"top","label":"Top"},{"value":"center","label":"Center"},{"value":"bottom","label":"Bottom"},{"value":"space-between","label":"Space between"}]},
    { "type":"select","id":"mobile_space_between_alignment","label":"Space Between","default":"center","options":[{"value":"top","label":"Top"},{"value":"center","label":"Center"},{"value":"bottom","label":"Bottom"}]},
    { "type":"range","id":"mobile_gap","min":0,"max":100,"step":1,"unit":"px","label":"Gap","default":16 },
    { "type":"header","content":"Padding Desktop" },
    { "type":"range","id":"padding_top","label":"Top","min":0,"max":200,"step":10,"default":40 },
    { "type":"range","id":"padding_bottom","label":"Bottom","min":0,"max":200,"step":10,"default":40 },
    { "type":"header","content":"Padding Mobile" },
    { "type":"range","id":"mobile_padding_top","label":"Top","min":0,"max":200,"step":10,"default":40 },
    { "type":"range","id":"mobile_padding_bottom","label":"Bottom","min":0,"max":200,"step":10,"default":40 }
  ],
  "presets":[{"name":"Custom Hero","category":"Custom"}]
}
{% endschema %}
