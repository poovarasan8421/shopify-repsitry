
{% assign bgBrightness = section.settings.hotspot_color | brightness_difference: '#fff' %}
{% style %}
  {% for block in section.blocks %}
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 {{ section.settings.hotspot_color | color_modify: 'alpha', 0.5 }}; }
      100% { box-shadow: 0 0 0 10px {{ section.settings.hotspot_color | color_modify: 'alpha', 0 }}; }
    }

    .{{ section.id }} .hotspot__button--{{ block.id }} {
      left: {{ block.settings.horizontal }}%;
      top: {{ block.settings.vertical }}%;
      background-color: {{ section.settings.hotspot_color }};
      animation: pulse 2s infinite;
    }

    .{{ section.id }} .hotspot__button--{{ block.id }}:hover {
      {% if bgBrightness < 125 %}
        background-color: {{ section.settings.hotspot_color | color_darken: 10 }};
      {% else %}
        background-color: {{ section.settings.hotspot_color | color_lighten: 10 }};
      {% endif %}
    }
  {% endfor %}

  .{{ section.id }} .hotspot__button path {
    {% if bgBrightness < 125 %}
      stroke: #000 !important;
    {% else %}
      stroke: #fff !important;
    {% endif %}
  }

  .{{ section.id }} .hotspot__button circle {
    {% if bgBrightness < 125 %}
      fill: #000 !important;
    {% else %}
      fill: #fff !important;
    {% endif %}
  }

  .{{ section.id }} .hotspot__button .icon-plus path {
    {% if bgBrightness < 125 %}
      fill: #000 !important;
      stroke: transparent;
    {% else %}
      fill: #fff !important;
      stroke: transparent;
    {% endif %}
  }
{% endstyle %}
{% assign block_product = false %}
{% for block in section.blocks %}
 {% if block.settings.featured_product != blank %}
  {% assign block_product = true %}
  {% endif %}
{%  endfor %}
 {% if section.settings.image != blank and block_product %}
<div class="index-section {{ section.id }} {{ bgBrightness }}">
  
  <hot-spots class="hotspots-wrapper {% unless section.settings.indent_image %}page-width{% endunless %} {% if section.settings.image_position == 'right' %}is-reverse{% endif %}">
    <div class="hotspots">
      <div class="hotspots__image hotspots__image--indent-{{ section.settings.indent_image }}">
        <div class="grid__image-ratio grid__image-ratio--square">
            {% comment %} {% liquid
                assign media_width_desktop = '100vw'
                assign media_width_mobile = '100vw'
                assign sizes = 'auto, (min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
                assign widths = '300, 450, 600, 750, 900, 1050, 1200, 1350, 1500, 1650, 1800, 1950, 2000, 2500, 3000, 3500, 4000, 5000'
                %}
              {% capture image %}
                {%- if section.settings.image -%}
                  {{
                    section.settings.image
                    | image_url: width: 3840
                    | image_tag:
                      width: section.settings.image.width,
                      widths: widths,
                      height:'auto',
                      class: 'image-block__image border-style',
                      style: image_border_style,
                      sizes: sizes
              }}
              {% endif %}
              {% endcapture %} {% endcomment %}
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width:1008 | image_tag: width: 1008 }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>

      <div class="hotspots__buttons">
        {% for block in section.blocks %}
          <button class="hotspot__button hotspot__button--{{ block.id}}" data-button="{{ block.id }}">
            {% assign buttonStyle = section.settings.hotspot_style %}
          
            {% if buttonStyle == 'dot' %}
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-dot" viewBox="0 0 12 12"><circle cx="6" cy="6" r="6" fill="currentColor"/></svg>
            {% elsif buttonStyle == 'plus' %}
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-plus" viewBox="0 0 20 20"><path fill="#444" d="M17.409 8.929h-6.695V2.258c0-.566-.506-1.029-1.071-1.029s-1.071.463-1.071 1.029v6.671H1.967C1.401 8.929.938 9.435.938 10s.463 1.071 1.029 1.071h6.605V17.7c0 .566.506 1.029 1.071 1.029s1.071-.463 1.071-1.029v-6.629h6.695c.566 0 1.029-.506 1.029-1.071s-.463-1.071-1.029-1.071z"/></svg>
            {% elsif buttonStyle == 'bag' %}
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-bag" viewBox="0 0 64 64"><g fill="none" stroke="#000" stroke-width="2"><path d="M25 26c0-15.79 3.57-20 8-20s8 4.21 8 20"/><path d="M14.74 18h36.51l3.59 36.73h-43.7z"/></g></svg>
            {% elsif buttonStyle == 'tag' %}
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-tag" viewBox="0 0 64 64"><path d="m46.69 10.34-10.55.07-25.8 25.8 17.45 17.45 25.8-25.8.07-10.55-6.97-6.97z"/><circle cx="43.95" cy="20.05" r="3.53"/><path d="M14.4 32.15 31.85 49.6"/></svg>
            {% endif %}
          </button>
        {% endfor %}
      </div>
    </div>
   
    <div class="hotspots__content swiper-container" data-block-container>
      {% if section.settings.title != blank %}
      <h2 class="hotspots__title {{ section.settings.heading_size }} text-{{ section.settings.heading_position }}">{{ section.settings.title }}</h2>
    {% endif %}
     <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% if block.settings.featured_product != blank %}
        <div class="hotspot-content__block swiper-slide  {% if forloop.index0 == 0 %}is-active{% endif %}" data-block-type="{{ block.type }}" data-hotspot-block="{{ block.id }}" {{ block.shopify_attributes }}>
          {% case block.type %}
            {% when 'product' %}
             {% assign product_card_id = 'product-card-link-' | append: block.id | append: '-' | append: product.id %} 
            <div class="product-content-wrap">
               {% capture card_children %}
                    {% render 'product-card-badges', product:block.settings.featured_product  %} 
               {% endcapture %}
                {% capture children %}
                {% content_for 'blocks', closest.product: block.settings.featured_product  %}
                
                {% endcapture %}
                {% liquid assign onboarding = false
                  if product.id == empty
                    assign onboarding = true
                  endif
                %}
              {% if block.settings.featured_product != blank %}
                {%- if settings.transition_to_main_product -%}
              <product-card-link
                data-product-id="{{ product.id }}"
                data-featured-media-url="{{ featured_media_url }}"
                data-product-transition="{{ settings.transition_to_main_product }}"
              >
            {%- endif -%}
            <product-card
              class="product-card"
              data-product-id="{{ product.id }}"
              data-product-variants-size="{{ product.variants.size }}"
              id="product-card-{{ block.id }}"
              data-product-transition="{{ settings.transition_to_main_product }}"
              {{ block.shopify_attributes }}
          >
            <a
              id="{{ product_card_id | md5 }}"
              {% unless onboarding %}
                href="{{ block.settings.featured_product.selected_or_first_available_variant.url }}"
                on:click="/navigateToProduct"
              {% endunless %}
              class="product-card__link"
              ref="productCardLink"
            >
              
              <span class="visually-hidden">
                {{ product.title }}
              </span>
            </a>
               {% comment %} <a href="{{ block.settings.featured_product.url }}"> {% endcomment %}
                {% render 'card-gallery', children: card_children, ref:'cart_drawer', product:block.settings.featured_product  %}
                {% render 'product-card', product: block.settings.featured_product,  children: children, quick_shop_enable: settings.quick_shop_enable, sizes: '30vw' %}
                 {% render 'text', fallback_text: block.settings.featured_product.title, block: block, ref:'shop-the-look', product:block.settings.featured_product %}
                 {% render 'price',
                  show_unit_price: true,
                  product_resource:block.settings.featured_product ,
                  show_sale_price_first: block.settings.show_sale_price_first
                  %} 
                {% comment %} </a> {% endcomment %}

              </product-card>
              {%- if settings.transition_to_main_product -%}
                </product-card-link>
              {%- endif -%}  
              {% endif %}
            
            </div>
            {% when 'paragraph' %}
              {% if block.settings.subheading != blank %}
                <p class="subheading">{{ block.settings.subheading }}</p>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3>{{ block.settings.heading }}</h3>
              {% endif %}

              {% if block.settings.content != blank %}
                {{ block.settings.content }}
              {% endif %}

              {% if block.settings.button_text != blank %}
                <a href="{{ block.settings.button_link }}" class="btn">{{ block.settings.button_text }}</a>
              {% endif %}
          {% endcase %}
        </div>
        {% endif %}
      {% endfor %}
    </div>
     
    <div class="swiper-navigiton-buttons">
     <div class="swiper-scrollbar"></div>
        <div class="swiper-button-prev">
         <svg xmlns="http://www.w3.org/2000/svg" width="41" height="41" viewBox="0 0 41 41" fill="none">
          <rect x="0.75" y="0.75" width="39.5" height="39.5" rx="19.75" stroke="black" stroke-width="1.5"/>
          <path d="M20.4993 13.6641L13.666 20.4974L20.4993 27.3307" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M27.3327 20.5H13.666" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
       </div>
     <div class="swiper-button-next">
      <svg xmlns="http://www.w3.org/2000/svg" width="41" height="41" viewBox="0 0 41 41" fill="none">
        <rect x="0.75" y="0.75" width="39.5" height="39.5" rx="19.75" stroke="black" stroke-width="1.5"/>
        <path d="M20.4993 13.6641L13.666 20.4974L20.4993 27.3307" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M27.3327 20.5H13.666" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
       </svg>
     </div>
   </div> 
    </div>
  </hot-spots>
</div>
{% endif %}
<style>

.hotspots-section .hotspots-wrapper {
     display: flex;
    flex-wrap: wrap;
    width:100%;
    overflow:hidden;
    align-items:stretch; 
  
}
.hotspots-section .hotspots-wrapper.is-reverse {
    flex-direction: row-reverse;
}
.hotspot-content__block {
  display: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.hotspots__title {
  width:100%;
  text-align:center;
  margin:0;
  font-size: 24px !important;
  line-height: 24px !important;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  font-weight:400 !important;
  color: #000000;

}
.hotspot-content__block.is-active {
  display: block;
  opacity: 1;
}
{% comment %} .hotspot-content__inner {
  display: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.hotspot-content__inner.is-active {
  display: block;
  opacity: 1;
} {% endcomment %}
.hotspots {
    position: relative;
    width: 50%;
}
.hotspots__buttons {
    background-color: transparent;
    border: 0;
    height: 100%;
    left: 0;
    position: absolute;
    top: 0;
    width: 100%;
}
.hotspot__button {
    border-radius: 50%;
    line-height: 0;
    padding: 10px;
    position: absolute;
    transform: translate(-50%, -50%);
}

 .hotspots__content {
    padding-left: 40px;
    padding-right: 0;
}
{% comment %} .is-reverse .hotspots__content {
   padding-left: clamp(16px, 2vw, 100px);
   padding-right: clamp(16px, 2vw, 100px);
} {% endcomment %}
.hotspots__content {
    align-items: center;
    display: flex;
    padding: 24px;
    width: 30%; 
    {% comment %} width:calc(100% - 50%); {% endcomment %}
    flex-wrap:wrap;
    position:relative;
    margin: 0 auto;
}
.hotspot-content__block {
    animation: fade-in .5s ease 0s forwards;
    display: none;
    max-height: 0;
    position: sticky;
    top: 0;
    width: 100%;
}
.hotspot-content__block.is-active {
    display: block;
    max-height: none;
}
{% comment %} .hotspots__content.swiper-container .swiper-wrapper{
  height:auto;
} {% endcomment %}
#shopify-section-{{section.id}} .swiper-button-prev{
  width:40px;
  height:40px;
  position:unset;
} 
#shopify-section-{{section.id}} .swiper-button-next{
  width:40px;
  height:40px;
  transform:rotate(180deg);
  position:unset;
}
.hotspots__content .swiper-button-prev:after,  
.hotspots__content .swiper-button-next:after{
  content:' ';
}
.hotspots__content .swiper-button-next svg, 
.hotspots__content .swiper-button-prev svg {
  width:35px;
  height:35px;
}
.hotspots__content .swiper-navigiton-buttons{
  display:flex; 
  gap: 20px;
  justify-content: end;
  width: 100%;
  position:absolute;
  right:0;
  bottom:0;
  align-items:flex-start;
}
.hotspots__content .product-content-wrap .text-block{
  font-family: 'Outfit';
  font-style: normal;
  font-weight: 400;
  font-size: 18px;
  line-height: 22px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #000000;
  margin:10px 0 5px 0;
}
.hotspots .hotspots__buttons{
  display:none;
}
.hotspots__content .product-content-wrap .price{
font-family: 'Helvetica-Neue';
font-style: normal;
font-weight: 300;
font-size: 12px;
line-height: 14px;
letter-spacing: 0.05em;
color: #000000;
}
.hotspots__content slideshow-component:hover slideshow-arrows{ 
   opacity:0;
}
{% comment %} .hotspots__content .quick-add__product-form-component{
  display:none;
} {% endcomment %}
.hotspots__content .swiper-navigiton-buttons .swiper-scrollbar{
  width:50%;
  bottom:unset;
  display: none;
}
.hotspots__content .quick-add{
  width:100%;
  height:100%;
}
.hotspots__content .quick-add__button{
  display:flex !important;
  box-shadow: none;
}
.hotspots__content .quick-add__button:disabled{
  display:none !important;
}
{% comment %} .hotspots__content .product-content-wrap{
  max-width:450px;
  margin:0 auto;
} {% endcomment %}
@media (min-width:1600px){ 
  .index-section{
    max-width:1440px;
    margin:0 auto;
  }
}
@media (max-width:767px){
.hotspots-section .hotspots-wrapper.is-reverse {
    flex-direction:column;
}
.hotspots__title{
  font-size: 18px;
  line-height: 20px;
}
.hotspots__content .product-content-wrap .text-block{
  font-size: 14px;
  line-height: 16px;
  font-weight:500;
}
.hotspots{
  width:100%;
}
.hotspots__content{
  width:100%;
}
.hotspots__content .swiper-navigiton-buttons{
  gap:8px;
}
.hotspots__content .swiper-button-next svg, 
.hotspots__content .swiper-button-prev svg{
  width: 30px;
  height: 30px;
}
}
</style>
{% schema %}
{
  "name": "shop the look",
  "class": "hotspots-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop the look"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        {
          "value": "h3",
          "label": "small"
        },
        {
          "value": "h2",
          "label": "medium"
        },
        {
          "value": "h1",
          "label": "large"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_position",
      "label": "Heading position",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "left"
        },
        {
          "value": "center",
          "label": "center"
        },
        {
          "value": "right",
          "label": "right"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "image",
      "info": "imageinfo"
    },
    {
      "type": "checkbox",
      "label": "indent_image",
      "id": "indent_image",
      "default": false
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "image position",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "left"
        },
        {
          "value": "right",
          "label": "right"
        }
      ]
    },
   /* {
      "type": "select",
      "id": "hotspot_style",
      "label": "hotspot style",
      "default": "bag",
      "options": [
        {
          "value": "dot",
          "label": "dot"
        },
        {
          "value": "plus",
          "label": "plus"
        },
        {
          "value": "tag",
          "label": "tag"
        },
        {
          "value": "bag",
          "label": "bag"
        }
      ]
    },*/
    {
      "type": "color",
      "id": "hotspot_color",
      "label": "hotspot color",
      "default": "#000000"
    },
    
     {
    "type":"header",
    "content":"Desktop Padding"
     },
     {
    "type": "range",
    "id": "padding_top",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "label": "Padding Top",
    "default": 34
     },
     {
    "type": "range",
    "id": "padding_bottom",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "label": "Padding Bottom",
    "default": 34
     },
     {
    "type":"header",
    "content":"Mobile Padding"
     },
     {
    "type": "range",
    "id": "padding_top_mob",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "label": "Padding Top",
    "default": 34
     },
     {
    "type": "range",
    "id": "padding_bottom_mob",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "label": "Padding Bottom",
    "default": 34
     }
  ],
  "blocks": [
    
    {
      "type": "product",
      "name": "product",
      "settings": [
        {
          "type": "product",
          "id": "featured_product",
          "label": "product"
        },
        {
          "type": "range",
          "id": "vertical",
          "label": "vertical",
          "default": 50,
          "min": 10,
          "max": 90,
          "step": 1,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "horizontal",
          "label": "horizontal",
          "default": 50,
          "min": 10,
          "max": 90,
          "step": 1,
          "unit": "%"
        }
      ]
    },
    {
      "type": "paragraph",
      "name": "paragraph",
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "subheading"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "content"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "range",
          "id": "vertical",
          "label": "vertical",
          "default": 50,
          "min": 10,
          "max": 90,
          "step": 1,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "horizontal",
          "label": "horizontal",
          "default": 50,
          "min": 10,
          "max": 90,
          "step": 1,
          "unit": "%"
        }
      ]
    } 
  ],
  "presets": [
    {
      "name": "shop the look",
    /* "blocks": [
        {
          "type": "product",
          "settings": {
            "vertical": 25,
            "horizontal": 25
          }
        },
        {
          "type": "product",
          "settings": {
            "vertical": 75,
            "horizontal": 65
          }
        }
      ]*/
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}