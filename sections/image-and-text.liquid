<div class="lafoli-section 
  {% if section.settings.image_position == 'right' %}lafoli-reverse{% endif %}
  {% if section.settings.mobile_position == 'content-first' %}lafoli-mobile-reverse{% endif %}
">
  <div class="lafoli-image">
    {% if section.settings.section_image %}
      <!-- Desktop image -->
      <img 
        class="lafoli-desktop-image"
        src="{{ section.settings.section_image | image_url: width: 1200 }}" 
        alt="{{ section.settings.heading | escape }}" 
        loading="lazy"
      >
    {% endif %}

    <!-- Mobile image (use uploaded mobile image or fallback to desktop) -->
    <img 
      class="lafoli-mobile-image"
      src="{% if section.settings.mobile_image != blank %}
              {{ section.settings.mobile_image | image_url: width: 800 }}
            {% else %}
              {{ section.settings.section_image | image_url: width: 800 }}
            {% endif %}" 
      alt="{{ section.settings.heading | escape }}" 
      loading="lazy"
    >
  </div>

  <div class="lafoli-content">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.content != blank %}
      <p>{{ section.settings.content }}</p>
    {% endif %}
  </div>
</div>

{% style %}
#shopify-section-{{ section.id }} .lafoli-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    padding-top: {{ section.settings.padding_top | default: 60 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
  }

#shopify-section-{{ section.id }} .lafoli-image{
    flex: 1 1 50%;
  }
#shopify-section-{{ section.id }} .lafoli-content 
{
    flex: 1 1 50%;
}

#shopify-section-{{ section.id }} .lafoli-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

#shopify-section-{{ section.id }} .lafoli-desktop-image { display: block !important; }
#shopify-section-{{ section.id }} .lafoli-mobile-image { display: none !important; }

#shopify-section-{{ section.id }} .lafoli-reverse { flex-direction: row-reverse; }

  @media (max-width: 768px) {
#shopify-section-{{ section.id }} .lafoli-section {
      flex-direction: column;
      text-align: center;
      padding-top: {{ section.settings.padding_top | default: 40 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 40 }}px;
    }

#shopify-section-{{ section.id }} .lafoli-desktop-image { display: none !important; }
#shopify-section-{{ section.id }} .lafoli-mobile-image { display: block !important; }

#shopify-section-{{ section.id }} .lafoli-mobile-reverse { flex-direction: column-reverse; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Image & Content",
  "settings": [
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position (Desktop)",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_position",
      "label": "Content / Image Order (Mobile)",
      "default": "image-first",
      "options": [
        { "value": "image-first", "label": "Image First, Content Second" },
        { "value": "content-first", "label": "Content First, Image Second" }
      ]
    },
    
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Image & Content",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
