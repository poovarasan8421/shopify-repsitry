{% schema %}
{
  "name": "Media Grid",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Media Grid"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section subheading",
      "default": "Subheading"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Section content",
      "default": "Enter any text.."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items (px)",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 10
    },
      {
    "type": "range",
    "id": "row_height_desktop",
    "label": "Row height (desktop, px)",
    "default": 300,
    "min": 50,
    "max": 1000,
    "step": 10
  },
      {
    "type": "range",
    "id": "row_height_mobile",
    "label": "Row height (mobile, px)",
    "default": 200,
    "min": 10,
    "max": 1000,
    "step": 10
  },
    {
     "type": "header",
     "content": "Desktop Spacing"
    },
    {
  "type": "range",
  "id": "padding_top_desktop",
  "label": "Padding top (desktop, px)",
  "default": 40,
  "min": 0,
  "max": 200,
  "step": 5
},
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom (desktop, px)",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 5
    },
    {
     "type": "header",
     "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile, px)",
      "default": 20,
      "min": 0,
      "max": 200,
      "step": 5
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile, px)",
      "default": 20,
      "min": 0,
      "max": 200,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL",
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "default": "25",
          "options": [
            { "value": "25", "label": "25%" },
            { "value": "50", "label": "50%" },
            { "value": "68", "label": "68%" },
            { "value": "100", "label": "100%" }
          ]
        },
        {
          "type": "select",
          "id": "row_span",
          "label": "Number of rows",
          "default": "1",
          "options": [
            { "value": "1", "label": "1" },
            { "value": "2", "label": "2" },
            { "value": "3", "label": "3" },
            { "value": "4", "label": "4" },
            { "value": "5", "label": "5" }
          ]
        }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (YouTube or Vimeo)",

        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "default": "25",
          "options": [
            { "value": "25", "label": "25%" },
            { "value": "50", "label": "50%" },
            { "value": "68", "label": "68%" },
            { "value": "100", "label": "100%" }
          ]
        },
        {
          "type": "select",
          "id": "row_span",
          "label": "Number of rows",
          "default": "1",
          "options": [
            { "value": "1", "label": "1" },
            { "value": "2", "label": "2" },
            { "value": "3", "label": "3" },
            { "value": "4", "label": "4" },
            { "value": "5", "label": "5" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Media Grid",
      "category": "Media"
    }
  ]
}
{% endschema %}

<style>
  #shopify-section-{{ section.id }} {
    overflow:hidden;
  }
#shopify-section-{{ section.id }} .media-grid-section {
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}

@media screen and (max-width: 749px) {
 #shopify-section-{{ section.id }} .media-grid-section {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
}

#shopify-section-{{ section.id }} .media-grid-section--page-width {
  max-width: 1200px;
  margin-left: auto;
  margin-right: auto;
  padding-left: 15px;
  padding-right: 15px;
}

#shopify-section-{{ section.id }} .media-grid-section--full-width {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
 
}

#shopify-section-{{ section.id }} .media-grid__header {
  text-align: {{ section.settings.text_alignment }};
}

#shopify-section-{{ section.id }} .media-grid__heading {
  font-size: 1.5rem;
  font-weight: 400;
  margin: 0 0 0.25em 0;
  color: #000;
}

#shopify-section-{{ section.id }} .media-grid__subheading {
  font-size: 1rem;
  color: #666;
  margin: 0 0 0.5em 0;
}

#shopify-section-{{ section.id }} .media-grid__content {
  font-size: 14px;
  color: #444;
  max-width: 700px;
  margin: 0 auto;
}

#shopify-section-{{ section.id }} .media-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: {{ section.settings.gap }}px;
}

#shopify-section-{{ section.id }} .media-grid__item {
  overflow: hidden;
  position: relative;
}

#shopify-section-{{ section.id }} .media-grid__item img,
#shopify-section-{{ section.id }} .media-grid__item iframe {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
 
}

/* Responsive row height for mobile */
@media screen and (max-width: 749px) {
  #shopify-section-{{ section.id }} .media-grid {
    grid-auto-rows: {{ section.settings.row_height_mobile }}px;
  }
}
</style>

<div class="media-grid-section {% if section.settings.section_width == 'page' %}media-grid-section--page-width{% else %}media-grid-section--full-width{% endif %}">

  {% if section.settings.heading or section.settings.subheading or section.settings.content %}
    <div class="media-grid__header">
      {% if section.settings.heading != blank %}
        <h2 class="media-grid__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <h3 class="media-grid__subheading">{{ section.settings.subheading }}</h3>
      {% endif %}
      {% if section.settings.content != blank %}
        <div class="media-grid__content">{{ section.settings.content }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="media-grid">
    {% for block in section.blocks %}
      {% assign col_span = 12 %}
      {% case block.settings.width %}
        {% when '25' %}
          {% assign col_span = 3 %}
        {% when '50' %}
          {% assign col_span = 6 %}
        {% when '68' %}
          {% assign col_span = 8 %}
        {% when '100' %}
          {% assign col_span = 12 %}
      {% endcase %}

      {% assign row_span = block.settings.row_span | default: 1 %}

<div class="media-grid__item" style="grid-column: span {{ col_span }}; grid-row: span {{ row_span }};">  
        {% if block.type == 'image' and block.settings.image %}
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" target="_blank" rel="noopener">
              <img src="{{ block.settings.image | img_url: '600x600' }}" alt="{{ block.settings.alt_text | escape }}">
            </a>
          {% else %}
            <img src="{{ block.settings.image | img_url: '600x600' }}" alt="{{ block.settings.alt_text | escape }}">
          {% endif %}
        {% elsif block.type == 'video' and block.settings.video_url %}
          <div class="video-wrapper" style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;">
            <iframe src="{{ block.settings.video_url | replace: 'watch?v=', 'embed/' }}" frameborder="0" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>