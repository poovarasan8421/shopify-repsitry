<div class="career__tab_section section" id="section-{{ section.id }}">
    <div class="section__width">
        {%- if section.settings.heading != blank or section.settings.content != blank -%}
        <div class="section_container">
            {%- if section.settings.heading != blank -%}
            <h2 class="section__heading">{{ section.settings.heading }}</h2>
            {%- endif -%}
            {%- if section.settings.content != blank -%}
            <p class="section_content">{{ section.settings.content }}</p>
            {%- endif -%}
        </div>
        {%- endif -%}
        <section id="wrapper">
            <div class="content">
                <!-- Tab links -->
                <div class="tabs">
                    {%- for block in section.blocks -%}
                    <p class="tablinks" data-country="tab-{{ forloop.index }}" dd="{{ forloop.index }}">{{ block.settings.tab_btn1 }}</p>
                    {%- endfor -%}
                </div>

                <!-- Tab content -->
                <div class="wrapper_tabcontent">
                    {%- for block in section.blocks -%}
                    <div id="tab-{{ forloop.index }}" class="tabcontent">
                        {% comment %} <p>{{ block.settings.accordion_content1 }}</p> {% endcomment %}
                         
                        {%- if block.settings.role1 != blank or block.settings.content1 != blank or block.settings.btn_link1 != blank -%}
                        <div class="job_opening">
                            <div class="contenttz">
                                {%- if block.settings.role1 != blank -%}
                                <p class="job_role">{{ block.settings.role1 }}</p>
                                {%- endif -%}
                                {%- if block.settings.content1 != blank -%}
                                <p class="block_content">{{ block.settings.content1 }}</p>
                                {%- endif -%}
                                <div class="bottom_content">
                                    {%- if block.settings.work_mode1 != blank -%}
                                    <p class="work_details">{% render 'map-pin-svg' %}{{ block.settings.work_mode1 }}</p>
                                    {%- endif -%}
                                    {%- if block.settings.time1 != blank -%}
                                    <p class="work_details">{% render 'clock-svg' %}{{ block.settings.time1 }}</p>
                                    {%- endif -%}
                                    {%- if block.settings.experience1 != blank -%}
                                    <p class="work_details">{% render 'brief-case-svg' %}{{ block.settings.experience1 }}</p>
                                    {%- endif -%}
                                </div>
                            </div>
                            <div class="button__side">
                                {%- if block.settings.btn_link1 != blank -%}
                                <a class="apply_btn" href="{{ block.settings.btn_link1 }}" target="_blank" aria-label="Click to Button"><span>{{ block.settings.btn_txt1 }}</span>{% render 'arrow-up-right-svg' %}</a>
                                {%- endif -%}
                            </div>
                        </div>
                        {% endif %}
                         
