<style>
#section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.Section_bg_clr }};
}

#shopify-section-{{ section.id }} .section__width {
    max-width: 740px;
    width: 100%;
    margin: auto;
}
#shopify-section-{{ section.id }} .section_container {
    text-align: center;
}
#shopify-section-{{ section.id }} .section__heading {
    font-family: 'Outfit';
    font-size: 20px;
    line-height: 22px;
    font-weight: 500;
    letter-spacing: 0.5PX;
    color: {{ section.settings.heading_clr }};
    margin: 0 0 21px;
    padding:0;
}
#shopify-section-{{ section.id }} .section_content {
    font-family: 'Helvetica-Neue';
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0.5px;
    font-weight: 400;
    color: {{ section.settings.content_clr }};
    margin: 0 0 37px;
}
#shopify-section-{{ section.id }} .tabs {
    display: flex;
    flex-wrap: nowrap;
    overflow-y: hidden;
    overflow-x: auto;
    gap: 26px;
    margin: 0 0 36px;
    padding: 0px;
}
#shopify-section-{{ section.id }} .tablinks {
    font-family:'Outfit' !important;
    font-size: 18px;
    line-height: 22px;
    letter-spacing: 0.5px;
    font-weight: 400;
    font-family: var(--font-h2--family);
    text-transform: uppercase;
    cursor: pointer;
    margin: 0;
    color: {{ section.settings.tab_btn_clr }};
    opacity: 0.5;
    white-space: nowrap;
}
#shopify-section-{{ section.id }} .tablinks.active {
    opacity: 1;
    border-bottom: 2px solid #00000091;
}
#shopify-section-{{ section.id }} .tabcontent {
    display: none;
}
#shopify-section-{{ section.id }} .tabcontent.active {
    transition: all 1s ease;
    display: block;
}
#shopify-section-{{ section.id }} .job_opening {
    border-top: 1px solid #d9d9d9;
    padding: 22px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
}
#shopify-section-{{ section.id }} .job_opening:last-child {
    border-bottom: 1px solid #d9d9d9;
}
#shopify-section-{{ section.id }} .job_role {
    font-family:'Outfit' !important;
    font-size: 18px;
    line-height: 22px;
    letter-spacing: 0;
    {% comment %} font-family: var(--font-h2--family); {% endcomment %}
    font-weight: 400;
    text-transform: uppercase;
    margin: 0 0 21px;
    color: {{ section.settings.tab_cnt_clr }};
}
#shopify-section-{{ section.id }} .block_content {
    font-family: 'Helvetica-Neue';
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0.5px;
    font-weight: 400;
    margin: 0 0 19px;
    color: {{ section.settings.tab_cnt_clr }};
}
#shopify-section-{{ section.id }} .bottom_content {
    display: flex;
    align-items: center;
    justify-content: space-between;
}
#shopify-section-{{ section.id }} .bottom_content .work_details {
    margin: 0;
    display: flex;
    align-items: center;
    font-size: 12px;
    line-height: 14px;
    letter-spacing: 0;
    font-weight: 300;
    color: {{ section.settings.tab_cnt_clr }};
    opacity: 0.5;
}
#shopify-section-{{ section.id }} .bottom_content .work_details svg {
    margin: 0 5px 0 0;
}
#shopify-section-{{ section.id }} .apply_btn {
    font-size: 18px;
    line-height: 22px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-family: var(--font-h2--family);
    font-weight: 400;
    color: {{ section.settings.tab_cnt_clr }};
    display: flex;
    align-items: center;
}
#shopify-section-{{ section.id }} .apply_btn span {
    text-decoration: underline;
}
#shopify-section-{{ section.id }} .apply_btn .arrow-up-svg {
    margin: 0 0 0 1px;
}
#shopify-section-{{ section.id }} .job_opening .contenttz {
    width: 67%;
}
#shopify-section-{{ section.id }} .tabs:before, 
#shopify-section-{{ section.id }} .tabs:after {
    content: '';
    flex: 1 1 auto;
}


@media (max-width: 749px){
#section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
}

#shopify-section-{{ section.id }} .section__heading {
    font-size: 18px;
    line-height: 20px;
    margin: 0 0 9px;
}
#shopify-section-{{ section.id }} .section_content {
    font-size: 11px;
    line-height: 16px;
    margin: 0 0 25px;
    font-weight: 300;
}
#shopify-section-{{ section.id }} .tablinks {
    font-size: 14px;
    line-height: 16px;
}
#shopify-section-{{ section.id }} .job_role {
    font-size: 14px;
    line-height: 16px;
    margin: 0 0 10px;

}

#shopify-section-{{ section.id }} .block_content {
    font-size: 11px;
    line-height: 16px;
    padding-right: 40px;
    font-weight:300;
    letter-spacing:0.6px;
}
#shopify-section-{{ section.id }} .job_opening .contenttz {
    width: 100%;
    margin: 0 0 16px;
}
#shopify-section-{{ section.id }} .bottom_content .work_details {
    font-size: 11px;
    line-height: 16px;
}
#shopify-section-{{ section.id }} .apply_btn {
    font-size: 14px;
    line-height: 16px;
}
#shopify-section-{{ section.id }} .tabs {
    margin: 0 0 27px;
}
#shopify-section-{{ section.id }} .job_opening {
    padding: 21px 0;
}
.job_opening:last-child {
    border-bottom: 1px solid #d9d9d9;
    margin-bottom: 25px !important;
}
}
</style>

<script>

var tabLinks = document.querySelectorAll("#shopify-section-{{ section.id }} .tablinks");
var tabContent = document.querySelectorAll("#shopify-section-{{ section.id }} .tabcontent");

tabLinks.forEach(function(el) {
   el.addEventListener("click", openTabs);
});

function openTabs(el) {
   var btnTarget = el.currentTarget;
   var country = btnTarget.dataset.country;

   tabContent.forEach(function(el) {
      el.classList.remove("active");
   });

   tabLinks.forEach(function(el) {
      el.classList.remove("active");
   });

   document.querySelector("#" + country).classList.add("active");
   btnTarget.classList.add("active");
}

// ✅ Set first tab active on page load
if (tabLinks.length > 0 && tabContent.length > 0) {
   tabLinks[0].classList.add("active");
   tabContent[0].classList.add("active");
}

</script>

