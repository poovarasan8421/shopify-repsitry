
{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-section-{{ ai_gen_id }} {
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.content_gap }}px;
    max-width: 100%;
  }

  .ai-image-text-container-{{ ai_gen_id }}--desktop-text-first {
    flex-direction: row-reverse;
  }

  .ai-image-text-container-{{ ai_gen_id }}--desktop-image-first {
    flex-direction: row;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
    text-align: {{ section.settings.desktop_text_alignment }};
    padding-left: {{ section.settings.text_padding_left}}px;
    padding-right: {{ section.settings.text_padding_right}}px;
    max-width: 50%;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ section.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    color: {{ section.settings.heading_color }};
    margin: 0 0 0px 0;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 24px;
    letter-spacing: 0.5px;
  }

  .ai-image-text-text-{{ ai_gen_id }} {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.6;
    letter-spacing: 0.03em;
    margin: 0;
   
  }

  .ai-image-text-button-wrapper-{{ ai_gen_id }} {
    text-align: {{ section.settings.desktop_button_alignment }};
  }

  .ai-image-text-button-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: {{ section.settings.button_margin_top }}px;
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
    background-color: {{ section.settings.button_background_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-image-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ section.settings.button_hover_background_color }};
    color: {{ section.settings.button_hover_text_color }};
  }

  .ai-desktop-image-{{ ai_gen_id }} {
     display: block !important;
   }

  .ai-mobile-image-{{ ai_gen_id }} {
     display: none !important;
     }
     
  @media screen and (max-width: 749px) {
    .ai-image-text-section-{{ ai_gen_id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    .ai-desktop-image-{{ ai_gen_id }} {
       display: none !important;
       }

    .ai-mobile-image-{{ ai_gen_id }} {
       display: block !important;
       }

    .ai-image-text-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ section.settings.mobile_content_gap }}px;
    }

    .ai-image-text-container-{{ ai_gen_id }}--mobile-text-first {
      flex-direction: column;
    }

    .ai-image-text-container-{{ ai_gen_id }}--mobile-image-first {
      flex-direction: column;
    }

    .ai-image-text-heading-{{ ai_gen_id }} {
      font-weight: 400;
    }

    .ai-image-text-text-{{ ai_gen_id }} {
      font-size: 12px;
      line-height:18px;
      letter-spacing: 0.05em;
      font-weight: 400;
    }

    .ai-image-text-button-wrapper-{{ ai_gen_id }} {
      text-align: {{ section.settings.mobile_button_alignment }};
    }

    .ai-image-text-button-{{ ai_gen_id }} {
      font-size: {{ section.settings.mobile_button_font_size }}px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      text-align: {{ section.settings.mobile_text_alignment }};
      padding-left: {{ section.settings.txt_mob_padding_left}}px;
      padding-right: {{ section.settings.txt_mob_padding_right}}px;
      max-width: 100%;
    }
    
  }
{% endstyle %}



<div class="ai-image-text-section-{{ ai_gen_id }}">
  <div class="ai-image-text-container-{{ ai_gen_id }} ai-image-text-container-{{ ai_gen_id }}--desktop-{{ section.settings.desktop_layout }} ai-image-text-container-{{ ai_gen_id }}--mobile-{{ section.settings.mobile_layout }}">

   <div class="ai-image-text-image-{{ ai_gen_id }}">
  <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
    {% if section.settings.image %}
      <!-- Desktop image -->
      <img
        class="ai-desktop-image-{{ ai_gen_id }}"
        src="{{ section.settings.image | image_url: width: 1000 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {% endif %}

    {% if section.settings.mobile_image != blank %}
      <!-- Mobile-specific image -->
      <img
        class="ai-mobile-image-{{ ai_gen_id }}"
        src="{{ section.settings.mobile_image | image_url: width: 800 }}"
        alt="{{ section.settings.mobile_image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.mobile_image.width }}"
        height="{{ section.settings.mobile_image.height }}"
      >
    {% else %}
      <!-- Fallback: show desktop image on mobile if no mobile image -->
      {% comment %} {% if section.settings.image %}
        <img
          class="ai-mobile-image-{{ ai_gen_id }}"
          src="{{ section.settings.image | image_url: width: 800 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
        >
      {% endif %} {% endcomment %}
    {% endif %}
  </div>
</div>


    <div class="ai-image-text-content-{{ ai_gen_id }}">
      {% if section.settings.heading != blank %}
        {% assign heading_tag = section.settings.heading_tag %}
        {% if heading_tag == 'default' %}
          <h2 class="ai-image-text-heading-{{ ai_gen_id }}">{{ section.settings.heading }}</h2>
        {% else %}
          <{{ heading_tag }} class="ai-image-text-heading-{{ ai_gen_id }}">{{ section.settings.heading }}</{{ heading_tag }}>
        {% endif %}
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="ai-image-text-text-{{ ai_gen_id }}">{{ section.settings.text }}</div>
      {% endif %}

      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <div class="ai-image-text-button-wrapper-{{ ai_gen_id }}">
          <a
            href="{{ section.settings.button_link }}"
            class="ai-image-text-button-{{ ai_gen_id }}"
          >
            {{ section.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Image with text new",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "mobile-Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
  "type": "select",
  "id": "heading_tag",
  "label": "Heading type",
  "options": [
    { "value": "default", "label": "Default (Theme style)" },
    { "value": "p", "label": "Paragraph" },
    { "value": "h1", "label": "Heading 1" },
    { "value": "h2", "label": "Heading 2" },
    { "value": "h3", "label": "Heading 3" },
    { "value": "h4", "label": "Heading 4" }
  ],
  "default": "h2"
},
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
    },
    {
      "type": "header",
      "content": "Desktop Text Padding"
    },
      {
  "type": "range",
  "id": "text_padding_left",
  "label": "Text Padding Left",
  "min": 0,
  "max": 120,
  "step": 2,
  "default": 10
},
{
  "type": "range",
  "id": "text_padding_right",
  "label": "Text Padding Right",
  "min": 0,
  "max": 120,
  "step": 2,
  "default": 10
},
    {
      "type": "header",
      "content": "Mobile Text Padding"
    },
    {
    "type": "range",
    "id": "txt_mob_padding_left",
    "label": "Padding Left",
     "min": 10,
      "max": 25,
      "unit": "px",
      "default": 10
    },
    {
    "type": "range",
    "id": "txt_mob_padding_right",
    "label": "Padding Right",
     "min": 10,
      "max": 25,
      "unit": "px",
      "default": 10
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "image-first",
          "label": "Image first"
        },
        {
          "value": "text-first",
          "label": "Text first"
        }
      ],
      "default": "image-first"
    },
    {
  "type": "select",
  "id": "desktop_text_alignment",
  "label": "Desktop text alignment",
  "options": [
    { "value": "left", "label": "Left" },
    { "value": "center", "label": "Center" },
    { "value": "right", "label": "Right" }
  ],
  "default": "left"
},

    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "image-first",
          "label": "Image first"
        },
        {
          "value": "text-first",
          "label": "Text first"
        }
      ],
      "default": "image-first"
    },
    {
  "type": "select",
  "id": "mobile_text_alignment",
  "label": "Mobile text alignment",
  "options": [
    { "value": "left", "label": "Left" },
    { "value": "center", "label": "Center" },
    { "value": "right", "label": "Right" }
  ],
  "default": "center"
},
    {
      "type": "range",
      "id": "content_gap",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Desktop content gap",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_content_gap",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Mobile content gap",
      "default": 20
    },
    {
      "type": "header",
      "content": "Desktop spacing"
