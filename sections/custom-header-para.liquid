<!-- sections/custom-text-para.liquid -->
<div class="lafoli-text-block">
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.description }}</p>
</div>

{% style %}
.lafoli-text-block {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  text-align: center;
  font-family: 'Manrope', sans-serif;
}

.lafoli-text-block h2 {
  font-size: {{ section.settings.heading_font_size }}px;
  font-weight: 400;
  line-height:24px;
  margin-bottom: {{ section.settings.heading_paragraph_gap }}px;
  font-family: 'Outfit', sans-serif;
  margin:0;

}

.lafoli-text-block p {
  font-size: {{ section.settings.text_font_size }}px;
  line-height: 20px;  
  letter-spacing: 0.5px;
  font-weight: 400;
  font-family: 'Helvetica-Neue';
  max-width: {{ section.settings.paragraph_max_width }}px;
  margin: 0 auto;
}

@media screen and (max-width: 768px) {
  .lafoli-text-block {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .lafoli-text-block h2 {
    font-size: {{ section.settings.heading_font_size_mobile }}px;
    font-weight:500;
    line-height:20px; 
    margin-bottom: {{ section.settings.heading_paragraph_gap_mobile }}px;
    padding:0;
  }

  .lafoli-text-block p {
    font-size: {{ section.settings.text_font_size_mobile }}px;
    max-width: {{ section.settings.paragraph_max_width_mobile }}px;
    padding: 0 16px;
    line-height: 16px;
    letter-spacing: 0.6px;
    font-weight:300;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "custom-text-para",
  "settings": [
    
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE DUO"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Born from a love for bold expression, LAFOLI bags are a modern icon of effortless luxury."
    },

    {
      "type": "header",
      "content": "Heading Font Size"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Desktop",
      "min": 16,
      "max": 60,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Mobile",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 24
    },

 {
      "type": "header",
      "content": "Paragraph Font Size"
    },    {
      "type": "range",
      "id": "text_font_size",
      "label": "Desktop",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "text_font_size_mobile",
      "label": "mobile",
      "min": 10,
      "max": 28,
      "step": 1,
      "default": 14
    },

      {
        "type": "header",
        "content": "Gap"
      }  ,
  {
      "type": "range",
      "id": "heading_paragraph_gap",
      "label": "desktop",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_paragraph_gap_mobile",
      "label": "Mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 12
    },
    {
      "type": "header",
      "content": "Padding Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 60
    },
    {
      "type": "header",
      "content": "Padding Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 40
    },

    {
      "type": "header",
      "content": "Width"
    },  
      {
      "type": "range",
      "id": "paragraph_max_width",
      "label": "Desktop",
      "min": 200,
      "max": 1000,
      "step": 10,
      "default": 600
    },
    {
      "type": "range",
      "id": "paragraph_max_width_mobile",
      "label": "Mobile",
      "min": 200,
      "max": 1000,
      "step": 10,
      "default": 600
    }
  ],
  "presets": [
    {
      "name": "custom-text-para"
    }
  ]
}
{% endschema %}
