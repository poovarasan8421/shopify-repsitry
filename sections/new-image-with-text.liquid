<div class="new-image-text" id="section-{{ section.id }}">
        <div class="new_image__text_custom_container {% if section.settings.image__first %}img_first{% else %}cont_first{% endif %}">
        <div class="image__box">
            {% liquid
                assign widths = '300, 450, 600, 750, 900, 1050, 1200, 1350, 1500, 1650, 1800, 1950, 2000, 2500, 3000, 3500, 4000, 5000'
            %}
            {% if section.settings.image != blank %}
            {% comment %}
            <img class="cust_txt_img" src="{{ section.settings.image | img_url:'master' }}" loading="lazy" width="800" height="auto" alt="{{ section.settings.image.alt }}">
            {% endcomment %}
           
            {{
            section.settings.image
            | image_url: width: 500
            | image_tag:
                width: section.settings.image.width,
                widths: widths,
                height: section.settings.image.height,
                class: 'img__desk'
            }}
            {% endif %}
            {% if section.settings.image_mob %}
            {{
            section.settings.image_mob
            | image_url: width: 750
            | image_tag:
                width: section.settings.image_mobwidth,
                widths: widths,
                height: section.settings.image_mob.height,
                class: 'img__mob'
            }}
            {% endif %}
        </div>
        <div class="content__box">
            <div class="cust__txt_inner">
                {% if section.settings.heading != blank %}
                <h2 class="image__heading">{{ section.settings.heading }}</h2>
                {% endif %}
                {% if section.settings.content != blank %}
                <p class="text__img_content">{{ section.settings.content }}</p>
                {% endif %}
            </div>
        </div>
        </div>
    </div>

<style>
#section-{{ section.id }} {
    background: {{ section.settings.bg_clr }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container {
    display: flex;
    align-items: center;
    line-height: 0;
    padding: 0px 70px; 
    {% comment %} padding: 0px 30px; {% endcomment %}
    {% comment %} gap:103px; {% endcomment %}
}

#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container.cont_first {
    flex-direction: row-reverse;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container.cont_first .cust__txt_inner {
   margin-left:80px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container.img_first .cust__txt_inner {
    margin-left: 100px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .image__box {
    width: 50%;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .image__box .img__desk {
    width: 100%;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box {
    width: 50%;
}
#shopify-section-{{ section.id }} .cust__txt_inner {
    max-width: 63%;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box .image__heading {
    font-size: 20px;
    font-weight: 500;
    line-height: 22px;
    letter-spacing: 0.05em;
    text-transform: capitalize;
    margin: 0px;
    color: {{ section.settings.heading_clr }};
    padding-bottom: 0px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box .text__img_content {
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: 0.05em;
    color: {{ section.settings.content_clr }};
    margin: 0;
    padding-top: 17px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box .text__img_content span {
    font-weight: 500;
    font-style: italic;
    font-family: "Barlow", sans-serif;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .image__box .img__mob {
    display: none;
}

@media (min-width: 750px) and (max-width: 1440px){
#shopify-section-{{ section.id }} .cust__txt_inner {    
    max-width: 91%;
}   
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container.cont_first .cust__txt_inner {
   margin-left:0px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container.img_first .cust__txt_inner {
    margin-left: 50px;
}
}
@media (max-width: 749px){
#section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top_mob }}px;
  padding-bottom: {{ section.settings.padding_bottom_mob }}px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container {
    padding:0px 0px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container.cont_first .cust__txt_inner {
   margin-left:0px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container.img_first .cust__txt_inner {
    margin-left: 0px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container {
    display: block;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .image__box,
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box {
    width: 100%;
    text-align: center;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .image__box .cust_txt_img {
    max-width: 100%;
}
{% comment %} #shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box {
    padding: 40px 0 42px;
} {% endcomment %}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box .image__heading {
    font-size: 18px;
    font-weight: 500;
    line-height: 20px;
    margin:0px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .image__box .img__desk {
    display: none;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .image__box .img__mob {
    display: block !important;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .image__box {
    width: 100%;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box {
    width: 100%;
}
#shopify-section-{{ section.id }} .new-image-text .section--page-width {
  grid-template-columns: auto;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .cust__txt_inner { 
 max-width: 1920px;
 text-align: left;
 padding: 24px 24px;
}
#shopify-section-{{ section.id }} .new-image-text .new_image__text_custom_container .content__box .text__img_content {
    font-size: 12px;
    line-height: 18px;
    font-weight: 400;
    padding-top: 16px;
}
}
</style>


{% schema %}
  {
    "name": "New Image Text",
    "settings": [
      {
      "type": "checkbox",
      "id": "image__first",
      "label": "Image First",
      "default": true
      },
      {
      "type": "image_picker",
      "id": "image",
      "label": "Image Desktop",
      "info": "Recommended Size: 1200 x 576"
      },
      {
      "type": "image_picker",
      "id": "image_mob",
      "label": "Image Mobile",
      "info": "Recommended Size: 1200 x 576"
      },
      {
      "type": "text",
      "id": "heading",
      "label": "Heading"
      },
      {
      "type": "textarea",
      "id": "content",
      "label": "Content"
      },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type":"header",
      "content":"Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
    "type": "header",
    "content":"Colour"
    },
    {
    "type": "color",
    "id": "bg_clr",
    "label": "Section Background Colour",
    },
    {
    "type": "color",
    "id": "heading_clr",
    "label": "Heading Colour",
    "default":"#000"
    },
    {
    "type": "color",
    "id": "content_clr",
    "label": "Content Colour",
    "default":"#000"
    }
    ],
"presets":[
    {
      "name": "New Image Text"
    }
  ]
  }
{% endschema %}