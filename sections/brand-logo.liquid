<div class="brand-logo-section">
       <div class="brand-logo-heading">
        {%- if section.settings.heading != blank -%}
            <h2 class="heading" style="color:{{ section.settings.heading-color }};">{{ section.settings.heading }}</h2>
        {%- endif -%}
       </div>
        <div class="brand-logo-slider-main" style="background:{{ section.settings.section-background }};">
            <div class="swiper">
                <div class="swiper-wrapper brand-logo-slider">
                    {%- for block in section.blocks -%}
                        <div class="swiper-slide">
                            <div class="image">
                                {%- if block.settings.image != blank -%}
                                    {{ block.settings.image | image_url: width: 600 | image_tag:
                                        class: 'image',
                                        loading: 'lazy',
                                        widths: '400, 500, 600, 800, 1000, 2000',
                                        sizes: '(max-width: 400px) 50vw',
                                        alt: block.settings.image.alt
                                    }}
                                {%- endif -%}
                            </div>
                        </div>
                    {%- endfor-%}
                </div>
            </div>
        </div>
        {%- if section.settings.dots != blank -%}
            <div class="swiper-pagination"></div> 
        {% endif %}
</div>

{% style %}
#shopify-section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}
#shopify-section-{{ section.id }} .brand-logo-section .heading {
    font-weight: 400;
    font-size: 24px;
    line-height: 24px;
    text-align: center;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 30px;
}
#shopify-section-{{ section.id }} .brand-logo-section .brand-logo-slider {
    display:flex;
    align-items: center;
    right:7px;
}
#shopify-section-{{ section.id }} .brand-logo-section .brand-logo-slider .image {
    margin: 0 auto;
    max-width: 155px;
}
#shopify-section-{{ section.id }} .brand-logo-section .brand-logo-slider .image img {
    height: 100%;
    width:100%;
    object-fit: contain;
    display: block;
    margin: 0 auto;
}
#shopify-section-{{ section.id }} .brand-logo-slider-main {
    padding:5px 0px;
}
#shopify-section-{{ section.id }} .brand-logo-section .swiper {
    margin: 0 auto;
    max-width:60%;
}
#shopify-section-{{ section.id }} .brand-logo-section .swiper-pagination-bullet-active {
  background: gray;
  opacity: 1;
}
#shopify-section-{{ section.id }} .brand-logo-section {
  position: relative;
}
#shopify-section-{{ section.id }} .brand-logo-section .swiper-pagination {
  position: absolute;
  bottom: -28px;
  left: 0;
  width: 100%;
  z-index: 2;
}  
@media only screen and (max-width: 767px) {
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
  }
  #shopify-section-{{ section.id }} .brand-logo-section .heading {
    font-weight: 500;
    font-size: 18px;
    line-height: 20px;
    /* letter-spacing: 0.03em; */
    margin:0;
  } 
  #shopify-section-{{ section.id }} .brand-logo-section .swiper {
    max-width:90%;
  }
  #shopify-section-{{ section.id }} .brand-logo-slider-main {
    padding:3px 0px;
 }
 /* .brand-logo-section .heading{
  display:none;
 } */
}
 @media screen and (max-width:400px){
 #shopify-section-{{ section.id }} .brand-logo-section .swiper {
    max-width:100%;
  }
 }
 @media only screen and (max-width: 767px) {
  #shopify-section-{{ section.id }} 
  .swiper-slide:nth-child(2) .image img {
    transform: scale(1.3); /* enlarge by 30% */
  }
