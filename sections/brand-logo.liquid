    margin-right: 10px !important;
  }

  #shopify-section-{{ section.id }} .brand-logo-section .brand-logo-slider .swiper-slide:nth-child(3) {
    margin-left: 10px !important;
  }
} */

{% endstyle %}

<script>
  document.addEventListener("DOMContentLoaded", function () {
    new Swiper("#shopify-section-{{ section.id }} .swiper", {
      loop: {{section.settings.loop}},
      watchOverflow: true,
      spaceBetween:20,
      pagination: {
        el: "#shopify-section-{{ section.id }} .swiper-pagination",
        clickable: true,
      },
      {%- if section.settings.autoplay -%}
      autoplay: {
        delay: 2000,
        disableOnInteraction: false
      },
      {%- endif -%}
      breakpoints: {
        0: {
          slidesPerView: 3,
        },
        640: {
          slidesPerView: 3,
        },
        768: {
          slidesPerView: 3,
        },
        1024: {
          slidesPerView: 3,
        },
        1280: {
          slidesPerView: 3,
        },
        1536: {
          slidesPerView: 3,
        },
        1920: {
          slidesPerView: 3,
        }
      }
    });
  });
</script>

{% schema %}
  {
    "name": "Brand Logo",
    "settings": [
   {
    "type": "text",
    "id": "heading",
    "label": "Heading"
  },
  {
    "type":"header",
    "content":"Appearance"
    },
    {
    "type": "color",
    "id": "heading-color",
    "label": "Heading Color",
    "default": "#000000"
  },
  {
    "type": "color",
    "id": "section-background",
    "label": "Section Background",
    "default": "#ffffff"
  },
   {
     "type":"header",
     "content":"Slider Layout"
   },
  {
    "type": "checkbox",
    "id": "dots",
    "label": "Enable Dots",
    "default": false
   },
   {
    "type": "checkbox",
    "id": "autoplay",
    "label": "Enable Autoplay",
    "default": false
   },
   {
    "type": "checkbox",
    "id": "loop",
    "label": "Enable Loop",
    "default": false
   },
     {
     "type":"header",
     "content":"Desktop Padding"
     },
     {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
     },
     {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
     },
     {
      "type":"header",
      "content":"Mobile Padding"
     },
     {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
     },
     {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
     }
    ],
    "blocks": [
     {
       "name": "Media",
       "type": "Block",
       "settings": [
         {
         "type": "image_picker",
         "id": "image",
         "label": "Image"
         }
       ]
     }
    ],
    "presets": [
      {
      "name":"Brand Logo"
      }
    ]
  }
{% endschema %}