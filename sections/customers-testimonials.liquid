              </svg>
            </span> {%endcomment %}
          </p>
              {% endif %}
          </div>
        </div>
        </div>           
        {% endfor %}
      </div>
  
      <div class="swiper-navigiton-buttons">
            <div class="swiper-button-prev">
            <svg xmlns="http://www.w3.org/2000/svg" width="41" height="41" viewBox="0 0 41 41" fill="none">
              <rect x="0.75" y="0.75" width="39.5" height="39.5" rx="19.75" stroke="black" stroke-width="1.5"/>
              <path d="M20.4993 13.6641L13.666 20.4974L20.4993 27.3307" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M27.3327 20.5H13.666" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
          </div>
        <div class="swiper-button-next">
          <svg xmlns="http://www.w3.org/2000/svg" width="41" height="41" viewBox="0 0 41 41" fill="none">
            <rect x="0.75" y="0.75" width="39.5" height="39.5" rx="19.75" stroke="black" stroke-width="1.5"/>
            <path d="M20.4993 13.6641L13.666 20.4974L20.4993 27.3307" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M27.3327 20.5H13.666" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>      
     </div>
</div>
</section> 



<style>
    #shopify-section-{{section.id}} {
      padding-top:{{section.settings.padding_top}}px;
      padding-bottom:{{section.settings.padding_bottom}}px;
    }
    #shopify-section-{{section.id}} .Customer-Testimonial_Section {
      background-size: cover;
        background-repeat: no-repeat;
      {% if section.settings.background_image_desktop != blank %}
          background-image: url("{{ section.settings.background_image_desktop | image_url: width: 2000 }}");
      {% endif %}
    }
    #shopify-section-{{section.id}} .bg-color-sec{
      padding: 50px;
    }
    #shopify-section-{{section.id}} .customer_testimonial{
      Border: 4px solid {{ section.settings.border_clr }} ;
      margin: 25px;
      background-color: {{ section.settings.bg_clr }}
      }

    #shopify-section-{{section.id}} .section-header-part h2{
      font-style: normal;
      font-weight: 400;
      font-size: 24px;
      line-height: 24px;
      /* identical to box height, or 100% */
      text-align: center;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color:{{section.settings.txt_clr}};
      margin-top: 20px;
      padding-bottom: 10px;
    }
    #shopify-section-{{section.id}} .content-image-wrap{
      display:flex;
      margin:0 auto;
      padding: 3rem ;
    }  
    #shopify-section-{{section.id}} .content-image-wrap .customer-image-wrap{
      width:50%;
      max-width: 46%;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-image-wrap .mobile-img{
      display:none;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews{
      width:calc(100% - 50%);
      display: flex;
      flex-direction: column;
      align-items: center; 
      text-align: center;
      justify-content: center;
      max-width: 36%;
      margin: 0 auto;
      padding-left: 3rem;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews svg{ 
      width: 41px;
      height: 41px;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews .star-rating{
      display:flex;
      margin-bottom: 20px;
      gap:15px;
    }

    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews h3.sub-heading-title{
      /* font-family: 'Outfit'; */
      font-style: normal;
      font-weight: 400 !important;
      font-size: 24px !important;
      line-height: 24px !important;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: {{section.settings.txt_clr}};
      margin:0;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews .reviwer-content{
      font-style: normal;
      max-width: 74%;
      font-weight: 400;
      font-size: 14px;
      line-height: 20px;
      letter-spacing: 0.05em;
      color: {{section.settings.txt_clr}};
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews .author{
      margin:0;
      display:flex;
      /* align-items:center; */
      color:{{section.settings.txt_clr}};
      gap:5px;
      font-weight: 300;
      font-style: Bold;
      font-size: 12px;
      line-height: 14px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
     
     /* font-family:'Providence Sans Bold';*/
    }
    /* #shopify-section-{{section.id}} .content-image-wrap .customer-reviews .author span{
      margin-top:3px;
    } */
    #shopify-section-{{section.id}} .swiper-navigiton-buttons{
      /* top: 65%; */
      bottom: 4%;
      position: absolute;
      right: 22%;
      z-index: 2;
      display: flex;
      gap: 16px;
      transform:translate(-10%, -27%)
    }
    #shopify-section-{{section.id}} .swiper-button-prev{
      width: 45px;
      height: 45px;
      position:unset;
    } 
    #shopify-section-{{section.id}} .swiper-button-next{
      width: 45px;
      height:45px;
      transform:rotate(180deg);
      position:unset;
    }
    #shopify-section-{{section.id}} .swiper-button-prev:after{
      content:unset;
    }
    #shopify-section-{{section.id}} .swiper-button-next:after{
      content:unset;
    }
    @media (max-width:1200px){
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews{
      max-width: 50%;
      margin: 0 auto;
      padding-left: 0rem;
    }
    #shopify-section-{{section.id}} .swiper-navigiton-buttons{
      right: 20%;
      transform: translate(-10%, -15%);
    }
    }
    @media (max-width:1100px){
      #shopify-section-{{section.id}} .bg-color-sec{
      padding: 20px;
    }
    #shopify-section-{{section.id}} .content-image-wrap{
      padding: 1rem ;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews h3.sub-heading-title{
      font-size: 18px !important;
      line-height: 24px !important;
   }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews .reviwer-content{
      font-size: 12px;
      line-height: 20px;
      max-width: 60%;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews .author{
      font-size: 11px;
    }
     #shopify-section-{{section.id}} .content-image-wrap .customer-reviews svg{ 
      width: 22px;
      height: 22px;
    }
    #shopify-section-{{section.id}} .swiper-navigiton-buttons{
      bottom: 4%;
      right: 18%;
      transform: translate(-10%, -5%);
    }
    #shopify-section-{{section.id}} .swiper-button-prev{
      width:32px;
      height:32px;
    }
    #shopify-section-{{section.id}} .swiper-button-next{
      width:32px;
      height:32px;
    }
    }
    @media (max-width:767px){
    #shopify-section-{{section.id}} {
      padding-top:{{section.settings.padding_top_mob}}px;
      padding-bottom:{{section.settings.padding_bottom_mob}}px;
    }
    #shopify-section-{{section.id}} .Customer-Testimonial_Section {
      {% if section.settings.background_image_mobile != blank %}
          background-image: url("{{ section.settings.background_image_mobile | image_url: width: 1000 }}");
      {% else %}
          background-image: url("{{ section.settings.background_image_desktop | image_url: width: 1000 }}");
      {% endif %}
    }

    #shopify-section-{{section.id}} .bg-color-sec{
      padding: 25px 0px;
    }
    #shopify-section-{{section.id}} .customer_testimonial {
      Border: 2px solid {{ section.settings.border_clr }} ;
      margin: 10px;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-image-wrap .desktop-img{
      display:none;
    } 
    #shopify-section-{{section.id}} .content-image-wrap .customer-image-wrap .mobile-img{
      display:block;
    } 
    #shopify-section-{{section.id}} .section-header-part h2{
      font-size: 18px;
      line-height: 20px;
      margin-bottom: 20px;
      font-weight:500;
      margin-top:0;
      padding-top:0;
    }
    #shopify-section-{{section.id}} .content-image-wrap{
      flex-direction:column;
      max-width:100%;
      padding:0 10px;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-image-wrap {
      width: 100%;
      padding: 10px 0 0;
      max-width: 100%
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews {
      max-width: 100%;
      {% comment %} padding:25px 0 30px; {% endcomment %}
      padding:25px 0 50px;
      width: 100%;
      align-items: start;
      text-align: left;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews svg{ 
      width: 17px;
      height: 17px;
    }
    
    #shopify-section-{{section.id}} .swiper-button-next{
      width:30px;
      height:30px;
    }
    #shopify-section-{{section.id}} .swiper-button-prev{
      width:30px;
      height:30px;
    }
    #shopify-section-{{section.id}} .swiper-navigiton-buttons {
      bottom: 3%;
      right: 1px;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews h3.sub-heading-title{
      font-size:18px !important;
      line-height:20px !important;
      font-weight:400 !important;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews .star-rating{
      margin-bottom:10px;
    }
    #shopify-section-{{section.id}} .content-image-wrap .customer-reviews .reviwer-content{
      margin-top:10px;
      font-size: 12px;
      line-height: 18px;
      max-width:100%;
    }
    }
    @media (max-width:400px){

    #shopify-section-{{section.id}} .Customer-Testimonial_Section {
      background-size: cover;
    }
  }
</style>  

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var swiper = new Swiper("#shopify-section-{{ section.id }} .customer_testimonial", {
      slidesPerView: 1,
      navigation: {
        nextEl: "#shopify-section-{{ section.id }} .swiper-button-next",
        prevEl: "#shopify-section-{{ section.id }} .swiper-button-prev"
      },
      loop: {{ section.settings.loop }},
      autoplay:{{ section.settings.autoplay }},
      // Optional: add pagination, autoplay, etc., if needed
      // pagination: {
      //   el: "#shopify-section-{{ section.id }} .swiper-pagination",
      //   clickable: true
      // }
    });
  });
</script>


{% schema %}
  {
    "name": "customers testimonials",
    "settings": [
