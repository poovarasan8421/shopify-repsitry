 {% liquid
    assign media_width_desktop = '25vw'
    assign media_width_mobile = '50vw'
    assign sizes = '(min-width: 750px) ' | append: media_width_desktop 
    assign Mob_sizes = '(max-width: 750px) ' | append: media_width_mobile 
    assign widths = '300, 450, 600,550,750,850, 950,'
  %}

 <section class=" Customer-Testimonial_Section"> 

<div class="page-width bg-color-sec
   section--{{ section.settings.section_width }}">
    <div class="section-header-part">
      <h2>{{ section.settings.head }}</h2>
    </div>
      <div class="customer_testimonial swiper" > 
        <div class="swiper-wrapper">
        {% for block in section.blocks %}
        <div class="swiper-slide" >
        <div class="content-image-wrap">
          <div class="customer-image-wrap">
            {% if block.settings.image %}
            {{
              block.settings.image
            | image_url: width: block.settings.image.width
            | image_tag:  sizes: sizes, widths: widths, class:'desktop-img',alt:'testimonial images'
          }}
            {% endif %}
          {% if block.settings.mob-image %}
            {{
              block.settings.mob-image
            | image_url: width:block.settings.mob-image.width 
            | image_tag:  sizes: Mob_sizes, widths: widths, class:'mobile-img',alt:'testimonial images'
          }}
            {% endif %}
          
          </div>
          <div class="customer-reviews">
            {% render 'reviews-stars' rating: block.settings.rating %}
            <h3 class="sub-heading-title">{{ block.settings.heading }}</h3>
            <p class="reviwer-content">{{ block.settings.review-content }}</p>
            {% if block.settings.review-name != blank %}
            <p class="author"> {{ block.settings.review-name }}
           {%comment %}   <span>
             <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 11 11" fill="none">
                <path d="M6.89327 4.0706L4.93551 6.02779L4.10615 5.19899C4.02593 5.12424 3.91984 5.08355 3.81021 5.08549C3.70059 5.08742 3.596 5.13183 3.51847 5.20936C3.44094 5.28688 3.39653 5.39148 3.3946 5.5011C3.39266 5.61073 3.43335 5.71682 3.5081 5.79703L4.63649 6.92542C4.6757 6.96479 4.7223 6.99604 4.77361 7.01735C4.82493 7.03867 4.87995 7.04964 4.93551 7.04964C4.99108 7.04964 5.0461 7.03867 5.09741 7.01735C5.14872 6.99604 5.19532 6.96479 5.23453 6.92542L7.49131 4.66865C7.56606 4.58843 7.60675 4.48234 7.60481 4.37271C7.60288 4.26309 7.55847 4.1585 7.48094 4.08097C7.40342 4.00344 7.29882 3.95903 7.1892 3.9571C7.07957 3.95516 6.97348 3.99585 6.89327 4.0706Z" fill="black"/>
                <path d="M8.26804 1.20164H7.61978C7.52979 1.20201 7.44063 1.18444 7.35751 1.14995C7.2744 1.11546 7.19899 1.06475 7.1357 1.00078L6.58222 0.447872C6.29511 0.161087 5.9059 0 5.5001 0C5.09429 0 4.70508 0.161087 4.41797 0.447872L3.8645 1.00078C3.80121 1.06475 3.7258 1.11546 3.64268 1.14995C3.55957 1.18444 3.47041 1.20201 3.38042 1.20164H2.73216C2.32634 1.20208 1.93727 1.36349 1.65032 1.65045C1.36336 1.93741 1.20195 2.32648 1.2015 2.73229V3.38055C1.20173 3.47047 1.18415 3.55954 1.14977 3.64262C1.11539 3.72571 1.0649 3.80116 1.00121 3.86463L0.447173 4.41811C0.160802 4.70544 0 5.09456 0 5.50023C0 5.9059 0.160802 6.29503 0.447173 6.58236L1.00121 7.13583C1.0649 7.1993 1.11539 7.27476 1.14977 7.35784C1.18415 7.44093 1.20173 7.53 1.2015 7.61991V8.26817C1.20195 8.67399 1.36336 9.06306 1.65032 9.35002C1.93727 9.63697 2.32634 9.79838 2.73216 9.79883H3.38042C3.47041 9.79846 3.55957 9.81603 3.64268 9.85052C3.7258 9.885 3.80121 9.93571 3.8645 9.99968L4.41797 10.5526C4.70523 10.8391 5.09438 11 5.5001 11C5.90581 11 6.29497 10.8391 6.58222 10.5526L7.1357 9.99968C7.19899 9.93571 7.2744 9.885 7.35751 9.85052C7.44063 9.81603 7.52979 9.79846 7.61978 9.79883H8.26804C8.67385 9.79838 9.06292 9.63697 9.34988 9.35002C9.63684 9.06306 9.79825 8.67399 9.7987 8.26817V7.61991C9.79847 7.53 9.81605 7.44093 9.85043 7.35784C9.8848 7.27476 9.9353 7.1993 9.99899 7.13583L10.553 6.58236C10.8394 6.29503 11.0002 5.9059 11.0002 5.50023C11.0002 5.09456 10.8394 4.70544 10.553 4.41811L9.99899 3.86407C9.9353 3.8006 9.8848 3.72514 9.85043 3.64206C9.81605 3.55898 9.79847 3.46991 9.7987 3.37999V2.73229C9.79825 2.32648 9.63684 1.93741 9.34988 1.65045C9.06292 1.36349 8.67385 1.20208 8.26804 1.20164ZM9.95723 5.01672C10.0852 5.1451 10.157 5.31897 10.157 5.50023C10.157 5.68149 10.0852 5.85536 9.95723 5.98375L9.40376 6.53779C9.26055 6.67923 9.14689 6.84775 9.06941 7.03352C8.99192 7.2193 8.95215 7.41862 8.9524 7.61991V8.26817C8.95225 8.44963 8.8801 8.62362 8.75179 8.75193C8.62348 8.88024 8.4495 8.95239 8.2680