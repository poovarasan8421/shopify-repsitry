<div class="page-width section--{{ section.settings.section_width }}">
  <div class="media-with-text-container">
  
    <div class="image-wrapper">
         {% if section.settings.image != blank %}
           <picture>
            {% if section.settings.mobile_image != blank %}
              <source 
                srcset="{{ section.settings.mobile_image | image_url: width: 600 }}" 
                media="(max-width: 749px)">
            {% endif %}

            <source 
              srcset="{{ section.settings.image | image_url: width: 1100 }}" 
              media="(min-width: 750px)">

            {{ section.settings.image | image_url: width: 1100 | image_tag: 
                class: '', 
                loading: 'lazy', 
                widths: '400, 500, 700, 800, 900, 1000, 1100', 
                sizes: '100vw', 
                alt: 'image' 
            }}
          </picture>
        {% endif %}
    </div>
        <div class="media-text-wrapper">
          <div class="text-container">
            <div class="text-content">
              {% if section.settings['media-title'] != blank %}
                <h2 class="media-title">{{ section.settings['media-title'] }}</h2>
                {% comment %} <hr class="media-separator"> {% endcomment %}
              {% endif %}
              <p>{{ section.settings['media-description'] }}</p>
            </div>
          </div>
          <div class="media-content">
           <div class="media-content-wrapper" style="position: relative; width:100%;">
            {% if section.settings.media_files == 'image' %} 
            {% if section.settings.cover_image != blank %}
            <picture>
            {{
              section.settings.cover_image
              | image_url: width: 1946
              | image_tag: widths: widths, sizes: sizes, loading: loading, class: 'deferred-media__poster-image desktop-image'
            }}
          </picture>
          {% endif %}

          <picture>
            {% if section.settings.mobile_cover_image != blank %}
              {{
                section.settings.mobile_cover_image
                | image_url: width: 800
                | image_tag: widths: widths, sizes: sizes, loading: loading, class: 'deferred-media__poster-image mobile-image'
              }}
            
            {% endif %}
          </picture>

        {% else %}
            {% if section.settings.source == 'uploaded' %}
              
              <!-- Desktop Video -->
              {% render 'video',
                video: section.settings.video,
                video_class: 'spacing-style size-style border-style desktop-video',
                video_loop: section.settings.video_loop,
                video_style: video_style,
                video_preview_image: section.settings.cover_image,
                additional_attributes: section.shopify_attributes,
                use_custom_play_svg:section.settings.video ,
                section_id: section.id
              %}

              <!-- Mobile Video -->
              {% render 'video',
                video: section.settings.test_video,
                video_class: 'spacing-style size-style border-style mobile-video',
                video_loop: section.settings.video_loop,
                video_style: video_style,
                additional_attributes: section.shopify_attributes,
                section_id: section.id,
                use_custom_play_svg: section.settings.test_video,
                mobile_video_preview_image: section.settings.mobile_cover_image
              %}

            {% else %}

              <!-- Video from URL -->
              {% render 'video',
                video_from_url: true,
                video: section.settings.video_url.id,
                video_class: 'spacing-style size-style border-style',
                video_type: section.settings.video_url.type,
                video_style: video_style,
                video_alt: section.settings.alt,
                video_preview_image: section.settings.cover_image,
                video_url_preview_image_mobile: section.settings.mobile_cover_image,
                additional_attributes: section.shopify_attributes,
                use_custom_play_svg: section.settings.video_url.id,
                section_id: section.id
              %}

            {% endif %}
            {% endif %}
          </div>
   </div>
  </div>
</div>
</div>

<style>
 #shopify-section-{{ section.id }} .mobile-image{
    display:none;
  }
 #shopify-section-{{ section.id }} .media-content-wrapper .mobile-video { display:none; }
  @media screen and (max-width:768px){
   #shopify-section-{{ section.id }} .media-content-wrapper .desktop-video { display:none; }
   #shopify-section-{{ section.id }} .media-content-wrapper .mobile-video { display:block; }
  }

  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .media-content-wrapper .spacing-style .deferred-media__poster-button {
   aspect-ratio: auto ;
  }
   #shopify-section-{{ section.id }} .media-content-wrapper .deferred-media__poster-icon svg, .video-placeholder-wrapper__poster-icon svg {
        width: 2rem;
        height: 2rem;
    }

  #shopify-section-{{ section.id }} .media-with-text-container {
    display: flex;
    width: 100%;
    margin: 0 auto;
    gap: 50px;
  }

  #shopify-section-{{ section.id }} .media-with-text-container .image-wrapper {
   width: 50%;
  }
  #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper {
   width: 50%;
   display: flex;
   flex-direction: column;
   gap: 30px;
  }
  #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container {
    max-width: 70%;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container .text-content .media-title {
    display: inline-block; 
    font-size: 24px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-bottom: 2px solid #0505058f;
    padding-bottom: 25px; 
  }
  #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container .text-content p {
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: 0.05em;
    color: #050505;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: end;
    gap: 20px;
  }
  #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container .text-content .media-separator {
   border: 1px solid #000000;
   margin: 15px 0;
  }

  @Media(max-width:1091px){
    #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container .text-content .media-title {
        font-size: 22px;
      }
  }

  @Media(max-width:810px){
    #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container .text-content .media-title {
        font-size: 20px;
      }
  }

  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container {
        max-width: 90%;
      }
      
  }


  @media (max-width: 768px) {
      #shopify-section-{{ section.id }} {
        padding-top: {{ section.settings.padding_top_mob }}px;
        padding-bottom: {{ section.settings.padding_bottom_mob }}px;
      }
      #shopify-section-{{ section.id }} .desktop-image{
          display:none
        }
        #shopify-section-{{ section.id }} .mobile-image{
          display:block
        }
      #shopify-section-{{ section.id }} .media-with-text-container {
        display: block;
        gap: 20px;
      }
      #shopify-section-{{ section.id }} .media-with-text-container .image-wrapper {
       width: 100%;
      }
      #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0px;
      }
      #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container {
        max-width: 100%;
        width: 100%;
        margin: 0 auto;
        padding: 25px;
      }
      #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container .text-content .media-title {
        font-size: 14px;
        line-height: 16px;
        letter-spacing: 5%;
        display: block; 
        padding-bottom: 13px;
        border-bottom: 2px solid #05050538;  
      }
      #shopify-section-{{ section.id }} .media-with-text-container .media-text-wrapper .text-container .text-content p {
        font-size: 11px;
        font-weight: 300;
        line-height: 16px;
        letter-spacing: 0.05em;
      }
  }
</style>

{% schema %}
{
  "name": "Media With Text",
  "settings": [
     {
      "type": "header",
      "content": "video or image"
    },
   {
      "type": "select",
      "id": "media_files",
      "label": "Media",
      "options": [
        { "value": "video", "label": "video" },
        { "value": "image", "label": "image" }
      ],
      "default": "video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Select Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Select Mobile Image"
    },

    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Desktop Image",
      
    },
    {
      "type": "image_picker",
      "id": "mobile_cover_image",
      "label": "Mobile Image",
     
    },
    {
      "type": "header",
      "content": "Media Contents"
    },
    {
      "type": "text",
      "id": "media-title",
      "label": "Media Title",
      "default": "The packaging experience"
    },
    {
      "type": "richtext",
      "id": "media-description",
      "label": "Description",
      "default": "<p>Enter the Description...</p>"
    },
    {
      "type": "header",
      "content": "Video"
    },
   {
      "type": "select",
      "id": "source",
      "label": "t:settings.video_source",
      "options": [
        { "value": "uploaded", "label": "t:options.video_uploaded" },
        { "value": "url", "label": "t:options.video_external_url" }
      ],
      "default": "uploaded"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Desktop Video",
      "visible_if": "{{ section.settings.source == 'uploaded' }}"
    },
    {
      "type": "video",
      "id": "test_video",
      "label": "Mobile Video",
      "visible_if": "{{ section.settings.source == 'uploaded' }}"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "t:settings.video_external_url",
      "accept": ["youtube","vimeo"],
      "visible_if": "{{ section.settings.source == 'url' }}"
    },
    
    {
      "type": "text",
      "id": "alt",
      "label": "Video Alt Text",
      
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Media With Text"
    }
  ]
}
{% endschema %}      
