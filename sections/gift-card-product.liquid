{% schema %}
{
  "name": "Gift Card Product",
  "settings": []
}
{% endschema %}

<div class="gift-card-wrapper">
  <div class="gift-card-grid">
    <!-- LEFT SIDE: Image -->
    <div class="gift-card-image">
      {{ product.featured_image | image_url: width: 600 | image_tag }}
    </div>

    <!-- RIGHT SIDE: Details -->
    <div class="gift-card-details">
      <h1>{{ product.title }}</h1>
      <p class="gift-card-price">{{ product.price | money }}</p>

      <!-- Denomination Buttons -->
      <div class="gift-card-denominations">
        {% for variant in product.variants %}
          <button type="button"
                  class="gift-btn"
                  data-variant="{{ variant.id }}">
            {{ variant.price | money }}
          </button>
        {% endfor %}
      </div>
{% form 'gift_card', gift_card %}
  {{ form.errors | default_errors }}
  
  <label for="gift_card_to">To</label>
  <input type="text" name="gift_card[to]" id="gift_card_to">

  <label for="gift_card_from">From</label>
  <input type="text" name="gift_card[from]" id="gift_card_from">

  <label for="gift_card_message">Message</label>
  <textarea name="gift_card[message]" id="gift_card_message"></textarea>

  {{ form | payment_button }}
{% endform %}

      <!-- Add to cart form -->
      <form method="post" action="/cart/add">
        <input type="hidden" name="id" id="selected_variant" value="{{ product.variants.first.id }}">
        <button type="submit" class="add-to-cart-btn">Add to Bag</button>
      </form>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.gift-btn').forEach(button => {
  button.addEventListener('click', function() {
    document.querySelectorAll('.gift-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    document.getElementById('selected_variant').value = this.dataset.variant;
  });
});
</script>

<style>
.gift-card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
  align-items: flex-start;
}
.gift-card-image img {
  max-width: 100%;
  border: 1px solid #eee;
}
.gift-card-price {
  font-size: 20px;
  font-weight: 600;
  margin: 10px 0;
}
.gift-card-denominations {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 15px 0;
}
.gift-btn {
  padding: 10px 20px;
  border: 1px solid #333;
  background: #fff;
  cursor: pointer;
}
.gift-btn.active {
  border-color: #900;
  background: #900;
  color: #fff;
}
.add-to-cart-btn {
  background: #900;
  color: #fff;
  padding: 15px;
  border: none;
  cursor: pointer;
  width: 100%;
  text-transform: uppercase;
}

</style>
