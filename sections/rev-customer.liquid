{% comment %} Add this schema for dynamic style
{
      "type": "style.size_panel",
      "id": "panel_size",
      "label": "Container Width & Height",
      "default": {
        "width": "100%",
        "height": "auto"
      }
    },
    {
      "type": "style.spacing_panel",
      "id": "panel_spacing_desk",
      "label": "Container Spacing (Desktop)",
      "default": {
        "padding": "50px 50px 50px 50px",
        "margin": "20px 0px 20px 0px"
      }
    },
    {
      "type": "style.spacing_panel",
      "id": "panel_spacing_mobile",
      "label": "Container Spacing (Mobile)",
      "default": {
        "padding": "10px 10px 10px 10px",
        "margin": "20px 0px 20px 0px"
      }
    }
{% endcomment %}

{% assign custom_meta_settings = shop.metafields.reverto_app.custom_settings.value %}

{% if custom_meta_settings.RevertoAppVersion == 2 %}
  {% render 'rev-v2-customer-data' %}
{% else %}
  {% render 'rev-customer-data' %}
{% endif %}

{% render 'rev-root' %}

 {% schema %}
 {
  "name": "Customer account",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type":"header",
      "content":"Sidebar Button"
    },
    {
      "type": "color",
      "id": "active_tab_bg_color",
      "label": "Active button background",
      "default": "#000"
    },
     {
      "type": "color",
      "id": "active_tab_text_color",
      "label": "Active button text",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "inactive_tab_bg_color",
      "label": "Button background",
      "default": "#fff"
    },
     {
      "type": "color",
      "id": "inactive_tab_text_color",
      "label": "Button text",
      "default": "#000"
    },
    {
      "type":"header",
      "content":"General Settings"
    },
    {
      "type": "color",
      "id": "general_background",
      "label": "General background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_background",
      "label": "Secondary background color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Primary button background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Primary button text",
      "default": "#00a3ff"
    },
    {
      "type": "color",
      "id": "secondary_button_background",
      "label": "Secondary button background",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "#000"
    },
    {
      "type": "color",
      "id": "heading_background",
      "label": "Heading background",
      "default": "#FAFAFA"
    },
    {
      "type": "color",
      "id": "heading_text",
      "label": "Heading text",
      "default": "#000"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "default": 14,
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "paragraph_font_size",
      "label": "Paragraph font size",
      "default": 12,
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "info_font_size",
      "label": "Info font size",
      "default": 10,
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type":"header",
      "content":"Container padding & margin"
    },
    {
      "type": "range",
      "id": "padding_top_bottom",
      "label": "Padding for desktop",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_bottom_mobile",
      "label": "Padding for mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top_bottom",
      "label": "Margin top and bottom for desktop",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top_bottom_mobile",
      "label": "Margin top and bottom for mobile",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "default": 100,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type":"header",
      "content":"Terms & conditions"
    },
    {
      "type": "select",
      "id": "content_option",
       "default": "link",
      "label": "Option Type",
      "options": [
        {
          "label": "Link",
          "value": "link"
        },
        {
          "label": "Content",
          "value": "content"
        }
      ]
    },
    {
      "type": "url",
      "id": "link",
      "label": "Terms & condition page link"
    },
    {
      "type": "richtext",
      "id": "content_text",
      "label": "Terms & condition text"
    }
  ]
}
{% endschema %}
