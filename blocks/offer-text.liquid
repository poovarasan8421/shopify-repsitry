<style>
#id-{{ block.id }}{
  padding-top:{{ block.settings.padding_top }}px;
  padding-bottom:{{ block.settings.padding_bottom }}px;
}
#id-{{ block.id }} .custom_offer_text{
    display:flex;
    background:{{ block.settings.background_color }};
    padding-top:24px;
    padding-bottom:24px;
    padding-left: 25px;
    align-items: center;
    gap: 8px;
  }
#id-{{ block.id }} .custom_offer_text .image_wrap-part img{
  width:22px;
}
#id-{{ block.id }} .custom_offer_text .text_wrap-part{
  font-family: 'Helvetica-Neue';
  font-style: normal;
  font-weight: 300;
  font-size: 12px;
  line-height: 14px;
  letter-spacing: 0.05em;
  color:{{ block.settings.badge_text_color }};
}
@media screen and (max-width:749px){
 #id-{{ block.id }}{
  padding-top:{{ block.settings.mob_padding_top }}px;
  padding-bottom:{{ block.settings.mob_padding_bottom }}px;
}
#id-{{ block.id }} .custom_offer_text{
  padding-top:18px;
  padding-bottom:18px;
}
#id-{{ block.id }} .custom_offer_text .text_wrap-part{
  font-size: 11px;
}
}
</style>
{% if block.settings.text %}
<div id="id-{{ block.id }}">
<div class="custom_offer_text">
    <div class="image_wrap-part">
     {% if block.settings.image != blank %}
     {{
      block.settings.image
      | image_url: width: 30
      | image_tag:
        width: block.settings.image.width,
        widths: widths,
        height: block.settings.image.height,
        class: 'image-block__image border-style',
        style: image_border_style,
        sizes: sizes
    }}
    {% endif %}
     </div>
    <div class="text_wrap-part">
        {{ block.settings.text }}
    </div>
</div>
</div>
{% endif %}

{% schema %}
{
  "name": "offer text",
  "tag": null,
  "settings": [
    {
     "type": "image_picker",
     "id": "image",
     "label": "image",
    },
    {
     "type": "text",
     "id": "text",
     "label": "Text",
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f8f8"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "mob_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "mob_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Bottom padding",
      "default": 40
    },

  ],
  "presets": [
    {
      "name": "Offer Text "
    }
  ],
  
}
{% endschema %}