<!-- Repeated multiple times (for each block) -->
<div class="faq-item">
  <div class="faq-tab-button">
    {{ block.settings.text }}
  </div>
</div>

<div class="nested-block-style">
  {% capture children %}
    {% content_for 'blocks' %}
  {% endcapture %}
  {{ children }}
</div>

   

<style>
#shopify-section-{{ section.id }} h2{
  padding: 5px 5px 0px 5px;
  cursor: pointer;
  text-align: center;
  font-size: 18px;
  font-family: 'Outfit', sans-serif;
  font-weight: 400;
  text-transform: uppercase;
  border-bottom: 2px solid transparent;
  transition: border 0.3s;
}
#shopify-section-{{ section.id }} .faq-tab-button{
  text-align: center;
  font-size: 18px ;
  font-family: 'Outfit', sans-serif ;
  font-weight: 400;
  text-transform: uppercase;
  border-bottom: 2px solid;
  
}

#shopify-section-{{ section.id }} .nested-block-style{
  max-width:900px;
  margin:0 auto;
  padding-top: 10px;
}
#shopify-section-{{ section.id }} .faq-tab-button.active-tab {
  border-bottom: 2px solid black;
  font-weight: 600;
}
#shopify-section-{{ section.id }} .faq-divider {
  height: 1px;
  background-color: #e0e0e0; /* Light grey line */
  margin: 20px auto;
  max-width: 900px;
}

</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const tabButtons = Array.from(document.querySelectorAll(".faq-tab-button"));
    const tabContents = Array.from(document.querySelectorAll(".nested-block-style"));

    if (tabButtons.length !== tabContents.length) {
      console.warn("Mismatch between tab buttons and content blocks.");
    }

    function showTab(index) {
      tabButtons.forEach((btn, i) => {
        btn.classList.toggle("active-tab", i === index);
      });
      tabContents.forEach((content, i) => {
        content.style.display = i === index ? "block" : "none";
      });
    }

    tabButtons.forEach((button, index) => {
      button.addEventListener("click", () => showTab(index));
    });

    if (tabButtons.length && tabContents.length) {
      showTab(0);
    }
  });
</script>


{% schema %}
{
  "name": "Custom_Group",
  "blocks": [
    {
      "type": "@theme"
    },
    {
    "type": "faq-nested-block"
    }
  ],
  "settings": [
    
    {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Enter your text here"
        }
  ],
  "presets": [
    {
      "name": "Custom_Group"
    }
  ]
}
{% endschema %}
