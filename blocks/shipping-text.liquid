<style>
#id-{{ block.id }} {
  padding-top:{{ block.settings.padding_top }}px;
  padding-bottom:{{ block.settings.padding_bottom }}px;
  padding-right:{{ block.settings.padding_right }}px;
  padding-left:{{ block.settings.padding_left }}px;
}  
#id-{{ block.id }} .shipping-text-product .shipping-tex-wrap p{
font-family: 'Helvetica-Neue';
font-style: normal;
font-weight: 400;
font-size: 14px;
line-height: 14px;
letter-spacing: 0.05em;
color: {{ block.settings.badge_text_color }};
}
@media screen and (max-width: 749px){
#id-{{ block.id }} {
  padding-top:{{ block.settings.mob_padding_top }}px;
  padding-bottom:{{ block.settings.mob_padding_bottom }}px;
  padding-right:{{ block.settings.mob_padding_right }}px;
  padding-left:{{ block.settings.mob_padding_right }}px;
} 
#id-{{ block.id }} .shipping-text-product .shipping-tex-wrap p{
font-size: 11px;
}
}
</style>
{% if block.settings.text %}
<div id="id-{{ block.id }}">
<div class="shipping-text-product">
    <div class="shipping-tex-wrap">
     <p>{{ block.settings.text }}</p>
    </div>
</div>
</div>
{% endif %}

{% schema %}
{
  "name": "Shipping text",
  "tag": null,
  "settings": [
   {
    "type": "text",
    "id": "text",
    "label": "text"
   },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f8f8"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
       "content": "Desktop Padding spaces"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default":0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Right padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Left padding",
      "default": 0
    },
    {
      "type": "header",
       "content": "Mobile Padding spaces"
    },
    {
      "type": "range",
      "id": "mob_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "mob_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Bottom padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "mob_padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Right padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "mob_padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Left padding",
      "default": 0
    },


  ],
  "presets": [
    {
        "name": "Shipping text"
    }
  ]
}
{% endschema %}