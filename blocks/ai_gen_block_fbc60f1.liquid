{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-images-block-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    width: 100%;
  }

  .ai-two-images-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: {{ block.settings.padding_width }}px;
    padding-right: {{ block.settings.padding_width }}px;
  }

  .ai-two-images-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap_desktop }}px;
    width: 100%;
  }

  .ai-two-images-item-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-two-images-item-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-two-images-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4/3;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-two-images-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-two-images-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-two-images-desktop-only-{{ ai_gen_id }} {
    display: block;
  }

  .ai-two-images-mobile-only-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-two-images-block-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-two-images-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-two-images-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.padding_width_mobile }}px;
      padding-right: {{ block.settings.padding_width_mobile }}px;
    }

    .ai-two-images-desktop-only-{{ ai_gen_id }} {
      display: none;
    }

    .ai-two-images-mobile-only-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<div class="ai-two-images-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-images-container-{{ ai_gen_id }}">
    <div class="ai-two-images-grid-{{ ai_gen_id }}">
      <div class="ai-two-images-item-{{ ai_gen_id }}">
        {% if block.settings.image_left_desktop %}
          <img
            src="{{ block.settings.image_left_desktop | image_url: width: 800 }}"
            alt="{{ block.settings.image_left_desktop.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_left_desktop.width }}"
            height="{{ block.settings.image_left_desktop.height }}"
            class="ai-two-images-desktop-only-{{ ai_gen_id }}"
          >
        {% endif %}
        
        {% if block.settings.image_left_mobile %}
          <img
            src="{{ block.settings.image_left_mobile | image_url: width: 600 }}"
            alt="{{ block.settings.image_left_mobile.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_left_mobile.width }}"
            height="{{ block.settings.image_left_mobile.height }}"
            class="ai-two-images-mobile-only-{{ ai_gen_id }}"
          >
        {% endif %}

        {% unless block.settings.image_left_desktop or block.settings.image_left_mobile %}
          <div class="ai-two-images-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-two-images-empty-state-{{ ai_gen_id }}">
              Add left image
            </div>
          </div>
        {% endunless %}
      </div>

      <div class="ai-two-images-item-{{ ai_gen_id }}">
        {% if block.settings.image_right_desktop %}
          <img
            src="{{ block.settings.image_right_desktop | image_url: width: 800 }}"
            alt="{{ block.settings.image_right_desktop.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_right_desktop.width }}"
            height="{{ block.settings.image_right_desktop.height }}"
            class="ai-two-images-desktop-only-{{ ai_gen_id }}"
          >
        {% endif %}
        
        {% if block.settings.image_right_mobile %}
          <img
            src="{{ block.settings.image_right_mobile | image_url: width: 600 }}"
            alt="{{ block.settings.image_right_mobile.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_right_mobile.width }}"
            height="{{ block.settings.image_right_mobile.height }}"
            class="ai-two-images-mobile-only-{{ ai_gen_id }}"
          >
        {% endif %}

        {% unless block.settings.image_right_desktop or block.settings.image_right_mobile %}
          <div class="ai-two-images-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-two-images-empty-state-{{ ai_gen_id }}">
              Add right image
            </div>
          </div>
        {% endunless %}
      </div>
    </div>
  </div>
</div>

