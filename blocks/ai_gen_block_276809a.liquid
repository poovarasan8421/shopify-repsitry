
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-careers-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-careers-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-careers-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-careers-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;font-weight: 600;
  }

  .ai-careers-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-careers-tabs-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 40px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    overflow-x: auto;
    padding-bottom: 0;
  }

  .ai-careers-tab-{{ ai_gen_id }} {
    padding: 12px 24px;
    background: none;
    border: none;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all 0.3s ease;
  }

  .ai-careers-tab-{{ ai_gen_id }}:hover {
    color: {{ block.settings.primary_color }};
  }

  .ai-careers-tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.primary_color }};
    border-bottom-color: {{ block.settings.primary_color }};
  }

  .ai-careers-listings-{{ ai_gen_id }} {
    display: none;
  }

  .ai-careers-listings-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-careers-job-{{ ai_gen_id }} {
    padding: 32px 0;
    border-bottom: 1px solid {{ block.settings.border_color }};display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }

  .ai-careers-job-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-careers-job-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-careers-job-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.job_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 00 12px;
    font-weight: 600;
  }

  .ai-careers-job-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin-bottom: 16px;
    opacity: 0.9;
    flex: 1;
  }

  .ai-careers-job-meta-{{ ai_gen_id }} {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .ai-careers-job-meta-item-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-careers-job-actions-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .ai-careers-apply-button-{{ ai_gen_id }} {
    background: none;
    color: {{ block.settings.button_color }};
    border: none;
    padding: 0;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: all 0.3s ease;
  }

  .ai-careers-apply-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_hover_color }};
    text-decoration-thickness: 2px;
  }

  .ai-careers-apply-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-careers-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-careers-popup-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-careers-popup-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-careers-popup-{{ ai_gen_id }} {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    background-color: {{ block.settings.popup_bg_color }};
    border-radius: {{ block.settings.popup_border_radius }}px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    max-width: {{ block.settings.popup_width }}px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    z-index: 1001;
    transition: transform 0.3s ease;
  }

  .ai-careers-popup-overlay-{{ ai_gen_id }}.active .ai-careers-popup-{{ ai_gen_id }} {
    transform: translate(-50%, -50%) scale(1);
  }

  .ai-careers-popup-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 24px 0;
    border-bottom: 1px solid {{ block.settings.border_color }};
    margin-bottom: 24px;
  }

  .ai-careers-popup-title-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-careers-popup-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .ai-careers-popup-close-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.border_color }};
  }

  .ai-careers-popup-content-{{ ai_gen_id }} {
    padding: 0 24px 24px;
  }

  .ai-careers-popup-block-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-careers-popup-block-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-careers-popup-heading-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
  }

  .ai-careers-popup-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-careers-popup-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: 8px;
    object-fit: cover;
  }

  .ai-careers-popup-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-careers-popup-image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-careers-popup-icon-{{ ai_gen_id }} {
    font-size: 24px;
    margin-bottom: 8px;
  }

  .ai-careers-popup-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-careers-popup-form-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ai-careers-popup-form-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .ai-careers-popup-form-input-{{ ai_gen_id }},
  .ai-careers-popup-form-textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 6px;
    font-size: 14px;
    transition: border-color 0.3s ease;
  }

  .ai-careers-popup-form-input-{{ ai_gen_id }}:focus,
  .ai-careers-popup-form-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.primary_color }};
  }

  .ai-careers-popup-form-textarea-{{ ai_gen_id }} {
    resize: vertical;
    min-height: 100px;
  }

  .ai-careers-popup-form-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    padding: 12px 24px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-careers-popup-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-careers-job-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .ai-careers-job-actions-{{ ai_gen_id }} {
      align-self: stretch;
    }

    .ai-careers-tabs-{{ ai_gen_id }} {
      justify-content: flex-start;padding: 0 20px 0 0;
    }

    .ai-careers-job-meta-{{ ai_gen_id }} {
      gap: 16px;
    }

    .ai-careers-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-careers-popup-{{ ai_gen_id }} {
      width: 95%;
      max-height: 85vh;
    }

    .ai-careers-popup-header-{{ ai_gen_id }},
    .ai-careers-popup-content-{{ ai_gen_id }} {
      padding-left: 16px;
      padding-right: 16px;
    }
  }
{% endstyle %}<careers-section-{{ ai_gen_id }}
  class="ai-careers-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-careers-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-careers-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-careers-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-careers-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-careers-tabs-{{ ai_gen_id }}">
      <button class="ai-careers-tab-{{ ai_gen_id }} active" data-category="all">
        VIEW ALL
      </button>
      <button class="ai-careers-tab-{{ ai_gen_id }}" data-category="development">
        DEVELOPMENT
      </button>
      <button class="ai-careers-tab-{{ ai_gen_id }}" data-category="design">
        DESIGN
      </button>
      <button class="ai-careers-tab-{{ ai_gen_id }}" data-category="marketing">
        MARKETING
      </button></div>

    <div class="ai-careers-listings-{{ ai_gen_id }} active" data-category="all">
      {% for i in (1..6) %}
        {% liquid
          assign job_title_key = 'job_' | append: i | append: '_title'
          assign job_description_key = 'job_' | append: i | append: '_description'
          assign job_category_key = 'job_' | append: i | append: '_category'
          assign job_location_key = 'job_' | append: i | append: '_location'
          assign job_type_key = 'job_' | append: i | append: '_type'
          assign job_experience_key = 'job_' | append: i | append: '_experience'

          assign job_title = block.settings[job_title_key]
          assign job_description = block.settings[job_description_key]
          assign job_category = block.settings[job_category_key]
          assign job_location = block.settings[job_location_key]
          assign job_type = block.settings[job_type_key]
          assign job_experience = block.settings[job_experience_key]
        %}

        {% if job_title != blank %}
          <div class="ai-careers-job-{{ ai_gen_id }}" data-category="{{ job_category }}">
            <div class="ai-careers-job-content-{{ ai_gen_id }}">
              <h3 class="ai-careers-job-title-{{ ai_gen_id }}">{{ job_title }}</h3>
              {% if job_description != blank %}
                <div class="ai-careers-job-description-{{ ai_gen_id }}">
                  {{ job_description }}
                </div>
              {% endif %}
              <div class="ai-careers-job-meta-{{ ai_gen_id }}">
                <span class="ai-careers-job-meta-item-{{ ai_gen_id }}">
                  📍 {{ job_location }}
                </span>
                <span class="ai-careers-job-meta-item-{{ ai_gen_id }}">
                  💼 {{ job_type }}
                </span>
                <span class="ai-careers-job-meta-item-{{ ai_gen_id }}">
                  ⭐ {{ job_experience }}
                </span>
              </div>
            </div>
            <div class="ai-careers-job-actions-{{ ai_gen_id }}">
              <button
                class="ai-careers-apply-button-{{ ai_gen_id }}"
                data-job-title="{{ job_title }}"
                data-job-index="{{ i }}"
              >
                APPLY
              </button>
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% assign has_jobs = false %}
      {% for i in (1..6) %}
        {% liquid
          assign job_title_key = 'job_' | append: i | append: '_title'
          assign job_title = block.settings[job_title_key]
        %}
        {% if job_title != blank %}
          {% assign has_jobs = true %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% unless has_jobs %}
        <div class="ai-careers-empty-state-{{ ai_gen_id }}">
          <p>No job listings available at the moment. Please check back later.</p>
        </div>
      {% endunless %}
    </div>

    <div class="ai-careers-listings-{{ ai_gen_id }}" data-category="development">
