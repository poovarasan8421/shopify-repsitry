  <div class="ai-careers-popup-overlay-{{ ai_gen_id }}" id="popup-overlay-{{ ai_gen_id }}">
    <div class="ai-careers-popup-{{ ai_gen_id }}">
      <div class="ai-careers-popup-header-{{ ai_gen_id }}">
        <h3 class="ai-careers-popup-title-{{ ai_gen_id }}" id="popup-title-{{ ai_gen_id }}">Apply for Position</h3>
        <button class="ai-careers-popup-close-{{ ai_gen_id }}" id="popup-close-{{ ai_gen_id }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="ai-careers-popup-content-{{ ai_gen_id }}">
        {% if block.settings.popup_heading != blank %}
          <div class="ai-careers-popup-block-{{ ai_gen_id }}">
            <h4 class="ai-careers-popup-heading-{{ ai_gen_id }}">{{ block.settings.popup_heading }}</h4>
          </div>
        {% endif %}

        {% if block.settings.popup_text != blank %}
          <div class="ai-careers-popup-block-{{ ai_gen_id }}">
            <div class="ai-careers-popup-text-{{ ai_gen_id }}">{{ block.settings.popup_text }}</div>
          </div>
        {% endif %}

        {% if block.settings.popup_image %}
          <div class="ai-careers-popup-block-{{ ai_gen_id }}">
            <img 
              src="{{ block.settings.popup_image | image_url: width: 600 }}" 
              alt="{{ block.settings.popup_image.alt | escape }}"
              class="ai-careers-popup-image-{{ ai_gen_id }}"
              loading="lazy"
            >
          </div>
        {% elsif block.settings.show_image_placeholder %}
          <div class="ai-careers-popup-block-{{ ai_gen_id }}">
            <div class="ai-careers-popup-image-placeholder-{{ ai_gen_id }}">
              {{'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}

        {% if block.settings.popup_icon != blank %}
          <div class="ai-careers-popup-block-{{ ai_gen_id }}">
            <div class="ai-careers-popup-icon-{{ ai_gen_id }}">{{ block.settings.popup_icon }}</div>
          </div>
        {% endif %}

        {% if block.settings.show_application_form %}
          <div class="ai-careers-popup-block-{{ ai_gen_id }}">
            {%- form 'contact' -%}
              <div class="ai-careers-popup-form-{{ ai_gen_id }}">
                <input type="hidden" name="contact[job_application]" value="true">
                <input type="hidden" name="contact[position]" value="" id="position-input-{{ ai_gen_id }}">
                
                <div class="ai-careers-popup-form-field-{{ ai_gen_id }}">
                  <label class="ai-careers-popup-form-label-{{ ai_gen_id }}" for="name-{{ ai_gen_id }}">Full Name *</label>
                  <input 
                    type="text" 
                    id="name-{{ ai_gen_id }}"
                    name="contact[name]" 
                    class="ai-careers-popup-form-input-{{ ai_gen_id }}"
                    required
                  >
                </div>

                <div class="ai-careers-popup-form-field-{{ ai_gen_id }}">
                  <label class="ai-careers-popup-form-label-{{ ai_gen_id }}" for="email-{{ ai_gen_id }}">Email Address *</label>
                  <input 
                    type="email" 
                    id="email-{{ ai_gen_id }}"
                    name="contact[email]" 
                    class="ai-careers-popup-form-input-{{ ai_gen_id }}"
                    required
                  >
                </div>

                <div class="ai-careers-popup-form-field-{{ ai_gen_id }}">
                  <label class="ai-careers-popup-form-label-{{ ai_gen_id }}" for="phone-{{ ai_gen_id }}">Phone Number</label>
                  <input 
                    type="tel" 
                    id="phone-{{ ai_gen_id }}"
                    name="contact[phone]" 
                    class="ai-careers-popup-form-input-{{ ai_gen_id }}"
                  >
                </div>

                <div class="ai-careers-popup-form-field-{{ ai_gen_id }}">
                  <label class="ai-careers-popup-form-label-{{ ai_gen_id }}" for="message-{{ ai_gen_id }}">Cover Letter</label>
                  <textarea 
                    id="message-{{ ai_gen_id }}"
                    name="contact[body]" 
                    class="ai-careers-popup-form-textarea-{{ ai_gen_id }}"
                    placeholder="Tell us why you're interested in this position..."
                  ></textarea>
                </div>

                <button type="submit" class="ai-careers-popup-form-button-{{ ai_gen_id }}">
                  Submit Application
                </button>

                {%- if form.posted_successfully? -%}
                  <div style="color: #008060; margin-top: 16px; padding: 12px; background-color: #f0f8f4; border-radius: 6px;">
                    Thank you! Your application has been submitted successfully.
                  </div>
                {%- endif -%}

                {%- if form.errors -%}
                  <div style="color: #D82C0D; margin-top: 16px; padding: 12px; background-color: #fef2f2; border-radius: 6px;">
                    Please check your form and try again.
                  </div>
                {%- endif -%}
              </div>
            {%- endform -%}
          </div>
        {% endif %}

