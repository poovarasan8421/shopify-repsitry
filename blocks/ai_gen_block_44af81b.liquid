      "content": "Shop all button"
    },
    {
      "type": "text",
      "id": "shop_all_button_text",
      "label": "Button text",
      "default": "Shop the complete look"
    },
    {
      "type": "url",
      "id": "shop_all_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
