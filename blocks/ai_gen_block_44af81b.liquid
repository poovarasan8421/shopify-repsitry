      "default": "Get the complete styled look with these curated pieces"
    },
    {
      "type": "image_picker",
      "id": "look_image",
      "label": "Look image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "3/4",
