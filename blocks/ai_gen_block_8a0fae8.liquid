{% doc %}

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-content-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top_desktop }}px {{ block.settings.padding_horizontal_desktop }}px {{ block.settings.padding_bottom_desktop }}px;
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    {% if block.settings.layout == 'image_right' %}
      flex-direction: row-reverse;
    {% endif %}
  }
  .layout-panel-flex{
        display: block;
  }
  .ai-image-content__image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    max-width: {{ block.settings.image_width }}%;
    width: 100%;
  }

  .ai-image-content__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-image-content__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4/3;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-content__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-content__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
  }

  .ai-image-content__content-{{ ai_gen_id }} {
    flex: 1;
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 30px 0 0;
  }

  .ai-image-content__heading-{{ ai_gen_id }} {
    margin: 0;
    color: #000000;
    font-size: {{ block.settings.heading_size }}px;
    font-weight:400;
    letter-spacing:0.5px;
    font-family:'Outfit';
    line-height: 1.2;
    max-width: {{ block.settings.heading_max_width }}px;
  }
  .ai-image-content__heading-{{ ai_gen_id }} h4{
     margin-bottom: 21px;
    color: #000000;
    font-size: {{ block.settings.heading_size }}px;
    font-weight:400;
    letter-spacing:0.5px;
    font-family:'Outfit';
    line-height: 1.2;
    max-width: {{ block.settings.heading_max_width }}px;
  }
  h2{
    text-transform: uppercase;
  }
  a {
    color: blue;
    text-decoration: none;
  }
    .ai-image-content__heading-{{ ai_gen_id }} h1,
  .ai-image-content__heading-{{ ai_gen_id }} h2,
  .ai-image-content__heading-{{ ai_gen_id }} h3,
  .ai-image-content__heading-{{ ai_gen_id }} h5,
  .ai-image-content__heading-{{ ai_gen_id }} h6 {
    margin: 0;
    color: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    font-family: inherit;
    line-height: inherit;
  }

  .ai-image-content__text-{{ ai_gen_id }} {
    margin: 0 0 24px 0;
    color: #000000;;
    font-size: 14px;
    font-weight: 400;
    letter-spacing:0.5px;
    font-family:'Helvetica-Neue';
    line-height: 20px;
    max-width: {{ block.settings.text_max_width }}px;
  }

  .ai-image-content__text-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
    color: #000000; 
    font-size:14px;
    font-weight: 400;
    letter-spacing:0.05em;
    font-family:'Helvetica-Neue';
    line-height:20px;
  }
  .ai-image-content__text-{{ ai_gen_id }} h6{
    color: #000000; 
    font-size:14px;
    font-weight: 400;
    letter-spacing:0.05em;
    font-family:'Helvetica-Neue';
    line-height:20px;
    margin: 0 0 5px 0;
  }
  .ai-image-content__text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-image-content__text-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }
 @media screen and (max-width: 1150px) {
    .ai-image-content-{{ ai_gen_id }} {
    gap: 125px !important;
  }
    }

     @media screen and (max-width: 900px) {
    .ai-image-content-{{ ai_gen_id }} {
    gap: 65px !important;
  }
    }

    
  @media screen and (max-width: 768px) {
    .ai-image-content-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
      flex-direction: column;
      gap: 40px !important;
    }

      .ai-image-content__heading-{{ ai_gen_id }} h2{
     padding-bottom: 0px;
      }
   
    .ai-image-content__image-wrapper-{{ ai_gen_id }} {
      flex: none;
      max-width: 100%;
      width: 100%;
    }

    .ai-image-content__image-{{ ai_gen_id }} {
      border-radius: {{ block.settings.image_border_radius_mobile }}px;
    }

    .ai-image-content__image-placeholder-{{ ai_gen_id }} {
      border-radius: {{ block.settings.image_border_radius_mobile }}px;
      aspect-ratio: {{ block.settings.mobile_image_aspect_ratio }};
    }

    .ai-image-content__content-{{ ai_gen_id }} {
      max-width: 100%;
    margin: 0 30px 0 20px !important;

    }

    .ai-image-content__heading-{{ ai_gen_id }} {
      font-size: 18px;
      margin-bottom: {{ block.settings.heading_gap_mobile }}px;
      max-width: 100%;
      font-weight:500;
    }

    .ai-image-content__text-{{ ai_gen_id }} {
      font-size: 11px;
      margin-bottom: {{ block.settings.text_gap_mobile }}px;
      max-width: 100%;
      font-weight:300;
    }
    strong {
    font-size: 12px;
    font-family: 'Helvetica-Neue';
    line-height: 18px;
    font-weight: 400;
    letter-spacing: 0.5px;
}
.ai-image-content__text-{{ ai_gen_id }} p {
    margin: 0 0 10px 0;
    font-weight:300;
    font-size:11px;
    line-height:16px;
  }
  .ai-image-content__text-{{ ai_gen_id }} h6{
    font-size:12px;
    line-height:18px;
  }
    .ai-image-content__text-{{ ai_gen_id }} {
    margin: 0 0 15px 0;
    }
      .ai-image-content__heading-{{ ai_gen_id }} h4{
        font-size:16px;
        font-weight:400;
        margin-bottom: 11px;
      }
  }

   
{% endstyle %}

<div class="ai-image-content-{{ ai_gen_id }}" {{ block.shopify_attributes }}><div class="ai-image-content__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      {% if block.settings.mobile_image != blank %}
        <picture>
          <source media="(max-width: 768px)" srcset="{{ block.settings.mobile_image | image_url: width: 400 }} 400w,
                  {{ block.settings.mobile_image | image_url: width: 600 }} 600w,
                  {{ block.settings.mobile_image | image_url: width: 800 }} 800w"
                  sizes="100vw">
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-image-content__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            sizes="(max-width: 768px) 100vw, {{ block.settings.image_width }}vw"
            srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                    {{ block.settings.image | image_url: width: 600 }} 600w,
                    {{ block.settings.image | image_url: width: 800 }} 800w,
                    {{ block.settings.image | image_url: width: 1000 }} 1000w,
                    {{ block.settings.image | image_url: width: 1200 }} 1200w">
        </picture>
      {% else %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          class="ai-image-content__image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          sizes="(max-width: 768px) 100vw, {{ block.settings.image_width }}vw"
          srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                  {{ block.settings.image | image_url: width: 600 }} 600w,
                  {{ block.settings.image | image_url: width: 800 }} 800w,
                  {{ block.settings.image | image_url: width: 1000 }} 1000w,
                  {{ block.settings.image | image_url: width: 1200 }} 1200w">{% endif %}
    {% else %}
      <div class="ai-image-content__image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-image-content__empty-state-{{ ai_gen_id }}">
          Add an image to get started
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-image-content__content-{{ ai_gen_id }}">
    {% if block.settings.heading_1 != blank %}
      <div class="ai-image-content__heading-{{ ai_gen_id }}">{{ block.settings.heading_1 }}</div>
    {% endif %}

    {% if block.settings.text_1 != blank %}
      <div class="ai-image-content__text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</div>
    {% endif %}

    {% if block.settings.heading_2 != blank %}
      <div class="ai-image-content__heading-{{ ai_gen_id }}">{{ block.settings.heading_2 }}</div>
    {% endif %}

    {% if block.settings.text_2 != blank %}
      <div class="ai-image-content__text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</div>
    {% endif %}

    {% if block.settings.heading_3 != blank %}
      <div class="ai-image-content__heading-{{ ai_gen_id }}">{{ block.settings.heading_3 }}</div>
    {% endif %}

    {% if block.settings.text_3 != blank %}
      <div class="ai-image-content__text-{{ ai_gen_id }}">{{ block.settings.text_3 }}</div>
    {% endif %}

    {% if block.settings.heading_4 != blank %}
      <div class="ai-image-content__heading-{{ ai_gen_id }}">{{ block.settings.heading_4 }}</div>
    {% endif %}

    {% if block.settings.text_4 != blank %}
      <div class="ai-image-content__text-{{ ai_gen_id }}">{{ block.settings.text_4 }}</div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Image with content",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "image_left",
          "label": "Image left"
        },
        {
          "value": "image_right",
          "label": "Image right"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "Image width",
      "default": 50
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 20,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "gap desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_gap_mobile",
      "min": 15,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "gap mobile",
      "default": 30
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Content max width",
      "default": 600
    },
    {
      "type": "richtext",
      "id": "heading_1",
      "label": "Heading 1",
      "default": "<h2>Your main heading</h2>"
    },
    {
      "type": "richtext",
      "id": "text_1",
      "label": "Text 1",
      "default": "<p>Add your first paragraph of content here. This text will appear below the first heading.</p>"
    },
    {
      "type": "richtext",
      "id": "heading_2",
      "label": "Heading 2"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Text 2"
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "min": 200,
      "max": 700,
      "step": 20,
      "unit": "px",
      "label": "Heading max width",
      "default": 500
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 18,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size desktop",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_gap",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Heading bottom gap desktop",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_gap_mobile",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading bottom gap mobile",
      "default": 16
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_max_width",
      "min": 200,
      "max": 700,
      "step": 20,
      "unit": "px",
      "label": "Text max width",
      "default": 500
    },   
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Top padding desktop",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding desktop",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal_desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding desktop",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Top padding mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding mobile",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Image with content"
    }
  ],
  "tag": null
}
{% endschema %}