
<div class="custom-nested-block">
  <div class="faq-item">
    <div class="faq-question">
      <span>{{ block.settings.heading }}</span>
      <span class="toggle-icon">+</span>
    </div>
    <div class="faq-answer" style="display: none;">
      {{ block.settings.text }}
    </div>
  </div>
</div>



  <style>
    {% comment %} #shopify-section-{{ section.id }} .custom-nested-block {
  width: 1000px !important;
  max-width: 1000px; {% endcomment %}
   
}
#shopify-section-{{ section.id }} .faq-item {
  border-bottom: 1px solid #eee;
  padding: 1rem 0;
  font-size: 14px;
  line-height: 20px;
  font-family: "Helvetica Neue", Helvetica, sans-serif;
  font-weight: 300;
  letter-spacing: 0.05em;
}
#shopify-section-{{ section.id }} .faq-question {
  cursor: pointer;
  font-weight: 600;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
#shopify-section-{{ section.id }} .faq-question span:last-child {
  font-weight: 300;
  font-size: 35px;
  transition: transform 0.3s;
}
#shopify-section-{{ section.id }} .faq-question.open span:last-child {
  transform: rotate(45deg);
}
#shopify-section-{{ section.id }} .faq-answer {
  display: none;
  margin-top: 0.5rem;
}
    </style>
    <script>
  document.addEventListener("DOMContentLoaded", function () {
    const questions = document.querySelectorAll(".custom-nested-block .faq-question");

    questions.forEach(question => {
      question.addEventListener("click", () => {
        const isOpen = question.classList.contains("open");
        const answer = question.nextElementSibling;
        const icon = question.querySelector(".toggle-icon");

        if (isOpen) {
          question.classList.remove("open");
          answer.style.display = "none";
          icon.innerText = "+";
        } else {
          question.classList.add("open");
          answer.style.display = "block";
          icon.innerText = "–";
        }
      });
    });
  });
</script>
{% schema %}
{
  "name": "nested block",
  "blocks": [
  ],
  "settings": [
    {
          "type": "text",
          "id": "heading",
          "label": "Text",
          "default": "Enter your Question"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Enter your Answer"
        }
  ],
  "presets": [
    {
      "name": "nested block"
    }
  ]
}
{% endschema %}
