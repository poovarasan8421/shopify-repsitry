{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-accordion-container-{{ ai_gen_id }} {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-accordion-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_bottom_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-accordion-tabs-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    margin-bottom: {{ block.settings.tabs_bottom_spacing }}px;
    border-bottom: 1px solid {{ block.settings.tab_border_color }};
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-accordion-tabs-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-accordion-tabs-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.tab_spacing }}px;
    min-width: max-content;
  }

  .ai-accordion-tab-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: {{ block.settings.tab_padding }}px 0;
    cursor: pointer;
    font-size: {{ block.settings.tab_font_size }}px;
    color: {{ block.settings.inactive_tab_color }};
    opacity: 0.6;
    transition: all 0.3s ease;
    position: relative;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 120px;
    text-align: center;
  }

  .ai-accordion-tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.active_tab_color }};
    opacity: 1;
  }

  .ai-accordion-tab-{{ ai_gen_id }}.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: {{ block.settings.underline_thickness }}px;
    background-color: {{ block.settings.active_tab_color }};
  }

  .ai-accordion-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.content_background_color }};
    border-radius: {{ block.settings.content_border_radius }}px;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-accordion-panel-{{ ai_gen_id }} {
    display: none;
  }

  .ai-accordion-panel-{{ ai_gen_id }}.active {
    display: block;
    animation: ai-accordion-fade-in-{{ ai_gen_id }} 0.3s ease-in-out;
  }

  .ai-accordion-item-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.item_spacing }}px;
    border-bottom: 1px solid {{ block.settings.accordion_border_color }};
  }

  .ai-accordion-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
    border-bottom: none;
  }

  .ai-accordion-item-header-{{ ai_gen_id }} {
    width: 100%;
    background: none;
    border: none;
    padding: {{ block.settings.accordion_item_padding }}px 0;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: {{ block.settings.accordion_title_size }}px;
    color: {{ block.settings.accordion_title_color }};
    font-weight: 600;
  }

  .ai-accordion-item-icon-{{ ai_gen_id }} {
    transition: transform 0.3s ease;
    color: {{ block.settings.accordion_icon_color }};
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-accordion-item-{{ ai_gen_id }}.open .ai-accordion-item-icon-{{ ai_gen_id }} {
    transform: rotate(45deg);
  }

  .ai-accordion-item-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    color: {{ block.settings.accordion_content_color }};
    font-size: {{ block.settings.accordion_content_size }}px;
    line-height: 1.6;
  }

  .ai-accordion-item-{{ ai_gen_id }}.open .ai-accordion-item-content-{{ ai_gen_id }} {
    max-height: 500px;
    padding-bottom: {{ block.settings.accordion_content_padding }}px;
  }

  @keyframes ai-accordion-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 900px) {
    .ai-accordion-container-{{ ai_gen_id }} {
      max-width: 100%;
      padding: {{ block.settings.container_padding | divided_by: 2 }}px;
    }
  }

  @media screen and (max-width: 768px) {
    .ai-accordion-tabs-{{ ai_gen_id }} {
      gap: {{ block.settings.tab_spacing | divided_by: 2 }}px;
    }

    .ai-accordion-tab-{{ ai_gen_id }} {
      font-size: {{ block.settings.tab_font_size | minus: 1 }}px;
      padding: {{ block.settings.tab_padding | minus: 2 }}px {{ block.settings.tab_padding | minus: 4 }}px;
      min-width: 100px;
    }

    .ai-accordion-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
      margin-bottom: {{ block.settings.heading_bottom_spacing | divided_by: 2 }}px;
    }

    .ai-accordion-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | divided_by: 2 }}px;
    }

    .ai-accordion-item-header-{{ ai_gen_id }} {
      font-size: {{ block.settings.accordion_title_size | minus: 2 }}px;
      padding: {{ block.settings.accordion_item_padding | minus: 4 }}px 0;
    }

    .ai-accordion-item-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.accordion_content_size | minus: 1 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-accordion-tab-{{ ai_gen_id }} {
      font-size: {{ block.settings.tab_font_size | minus: 2 }}px;
      padding: {{ block.settings.tab_padding | minus: 4 }}px {{ block.settings.tab_padding | minus: 6 }}px;
      min-width: 80px;
    }

    .ai-accordion-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-accordion-item-header-{{ ai_gen_id }} {
      font-size: {{ block.settings.accordion_title_size | minus: 3 }}px;
    }

    .ai-accordion-item-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.accordion_content_size | minus: 2 }}px;
    }
  }
{% endstyle %}

<accordion-tabs-{{ ai_gen_id }} class="ai-accordion-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.main_heading != blank %}
    <h2 class="ai-accordion-heading-{{ ai_gen_id }}">{{ block.settings.main_heading }}</h2>
  {% endif %}<div class="ai-accordion-tabs-wrapper-{{ ai_gen_id }}">
    <div class="ai-accordion-tabs-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% assign tab_title_key = 'tab_' | append: i | append: '_title' %}
        {% assign tab_title = block.settings[tab_title_key] %}
        {% if tab_title != blank %}
          <button 
            class="ai-accordion-tab-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}" 
            data-tab="{{ i }}"
          >
            {{ tab_title }}
          </button>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="ai-accordion-content-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% assign tab_title_key = 'tab_' | append: i | append: '_title' %}
      {% assign tab_title = block.settings[tab_title_key] %}
      {% if tab_title != blank %}
        <div class="ai-accordion-panel-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}" data-panel="{{ i }}">
          {% for j in (1..5) %}
            {% assign item_title_key = 'tab_' | append: i | append: '_item_' | append: j | append: '_title' %}
            {% assign item_content_key = 'tab_' | append: i | append: '_item_' | append: j | append: '_content' %}
            {% assign item_title = block.settings[item_title_key] %}
            {% assign item_content = block.settings[item_content_key] %}
            {% if item_title != blank %}
              <div class="ai-accordion-item-{{ ai_gen_id }}">
                <button class="ai-accordion-item-header-{{ ai_gen_id }}">
                  <span>{{ item_title }}</span>
                  <svg class="ai-accordion-item-icon-{{ ai_gen_id }}" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </button>
                <div class="ai-accordion-item-content-{{ ai_gen_id }}">
                  {% if item_content != blank %}
                    {{ item_content }}
                  {% else %}
                    <p>Add content for this accordion item.</p>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</accordion-tabs-{{ ai_gen_id }}>

<script>
(function() {
  class AccordionTabs{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.tabs = this.querySelectorAll('.ai-accordion-tab-{{ ai_gen_id }}');
      this.panels = this.querySelectorAll('.ai-accordion-panel-{{ ai_gen_id }}');
      this.accordionItems = this.querySelectorAll('.ai-accordion-item-{{ ai_gen_id }}');
      
      this.setupTabListeners();
      this.setupAccordionListeners();
    }

    setupTabListeners() {
      this.tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const tabNumber = tab.dataset.tab;
          
          this.tabs.forEach(t => t.classList.remove('active'));
          this.panels.forEach(p => p.classList.remove('active'));
          
          tab.classList.add('active');
          const targetPanel = this.querySelector(`[data-panel="${tabNumber}"]`);
          if (targetPanel) {
            targetPanel.classList.add('active');
            this.accordionItems.forEach(item => {
              if (targetPanel.contains(item)) {
                item.classList.remove('open');
              }
            });
          }
        });
      });
    }

    setupAccordionListeners() {
      this.accordionItems.forEach(item => {
        const header = item.querySelector('.ai-accordion-item-header-{{ ai_gen_id }}');
        
        header.addEventListener('click', () => {
          const isOpen = item.classList.contains('open');
          
          if (isOpen) {
            item.classList.remove('open');
          } else {
            item.classList.add('open');
          }
        });
      });
    }
  }

  customElements.define('accordion-tabs-{{ ai_gen_id }}', AccordionTabs{{ ai_gen_id }});
})();
</script>

