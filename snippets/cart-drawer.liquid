{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
{% comment %}
  <script
    src="{{ 'slideshow.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endcomment %}

<cart-drawer-component
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  <button
    class="button header-actions__action button-unstyled"
    on:click="/open"
    aria-label="{{ 'accessibility.open_cart_drawer' | t }} {{ 'accessibility.cart_count' | t}}: {{ cart.item_count }}"
  >
    {% render 'cart-icon-component' %}
  </button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      <cart-items-component
        class="cart-items-component"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          <div class="cart-drawer__header">
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {% comment %} {{- 'icon-close.svg' | inline_asset_content -}} {% endcomment %}
                {{- 'cart-close-icon.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
          >
            <span class="cart-drawer__heading h3 cart-drawer__heading--empty">
              {{ 'content.your_cart_is_empty' | t }}
            </span>

            <div class="cart-drawer__items">
              {% render 'cart-products' %}
            </div>
          </div>
        {%- else -%}
          <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {% comment %} {{- 'icon-close.svg' | inline_asset_content -}} {% endcomment %}
                {{- 'cart-close-icon.svg' | inline_asset_content -}}
              </span>
            </button>
          <div
            class="cart-drawer__header"
            id="cart-drawer-header"
          >
            <span class="cart-drawer__heading h3">
              {{ 'content.cart_title' | t }}
              {% render 'cart-bubble' %}
            </span>

            {% comment %} <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {% comment %} {{- 'icon-close.svg' | inline_asset_content -}} {% endcomment %}
                {{- 'cart-close-icon.svg' | inline_asset_content -}}
              </span>
            </button> {% endcomment %}
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 60px;"
          >
            <scroll-hint
              class="cart-drawer__items"
            >
              {% render 'cart-products' %}

               {% if cart != empty  %}
                {% if settings.discount-text != blank %}
                <div class="static-discount-text">
                  <p>{{ settings.discount-text }}</p>
                </div>
              {% endif %}
                {% if settings['product-list'] != blank %}
                <div class="cart__recommended_product">
                  {%- if settings['recommendated-title'] != blank -%}
                    <h4 class="recommendated__title">{{ settings['recommendated-title'] }}</h4>
                  {%- endif -%}

                  <div class="swiper product-list-block cart__recommended_product_slide">
                    <ul class="product__container product-grid swiper-wrapper">
                      {% assign catr_first_item = cart.items | first %}
                      {% assign first_product_type = catr_first_item.product.type %}
                      {% assign meta_product = catr_first_item.product.metafields.custom.cart_drawer_you_may_also_like.value %}
                      
                      {%- if meta_product != blank -%}
                        {%- for product in meta_product -%}
                          <li class="grid__item swiper-slide">
                            {% render 'product-card', children: children, product: product %}
                          </li>
                        {%- endfor -%}

                      {%- else -%}
                        {%- for product in settings['product-list'] -%}
                          {% assign block = forloop.index %}
                          {% capture card_children %}
                          {% render 'product-card-badges', product:product %} 
                      {% endcapture %}
                          {% capture custom_children %}
                   <div class="overall-continer">  
                    <div class="product_custom_gallery"> 
                    {% render 'card-gallery', children:card_children, ref:"cart_drawer", product:product  %} 
                    
                    </div>
                  <div class="custom_content-wrap">
                    <div class="custom-title-price">
                      {% if product == blank and request.design_mode %}
                      {% assign text = 'placeholders.product_title' | t %}
                      {% assign product_title = '<p>' | append: text | append: '</p>' %}
                      {% render 'text', fallback_text: product_title, block: block %}
                     {% elsif product != blank %}
                      {% assign product_title = '<p>' | append: product.title | append: '</p>' %}
                      {% render 'text', ref:"cart_drawer", fallback_text: product_title, block: block, product:product %}
                      {% endif %} 
                      <product-price data-product-id="{{ product.id }}">
                      {% render 'price', product_resource: product, show_unit_price: false %}
                      </product-price>
                    </div>
                    <div class="custom_quick-add-btn">
                     {% if settings.quick_add or settings.mobile_quick_add %}
  
                     {% render 'quick-add', product:product, ref:'cart_drawer', block:block , section_id: section.id, loop:forloop.index %}
                     {% endif %}
                     </div>
                  </div>
                   
                  </div>
                   
                  
                  {% endcapture %}

                          <li class="grid__item swiper-slide">
                            {% render 'product-card', children: custom_children, product: product %}
                          </li>
                        {%- endfor -%}
                      {%- endif -%}
                    </ul>

                    <div class="swiper-button-next"></div>
                    <div class="swiper-button-prev"></div>
                  </div>
                </div>
              {% endif %} 
              {% endif %}
            </scroll-hint>

            <div
              class="cart-drawer__summary"
            >
              {% render 'cart-summary' %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{% comment %} {% render 'account-drawer' %} {% endcomment %}

{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .cart-drawer__inner .grid__item{
    /* background: #fff; */
    border: 0.5px solid #000;
    height: auto;
  }
  .cart-drawer__dialog .cart-items__details div{
    display: flex;
    align-items:center;
    gap:8px;
    flex-wrap:wrap;
  }
  .cart-drawer__inner .custom_quick-add-btn{
     margin-top:5px;
  }
  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 26px;
  }

  /* .cart-bubble{
    display:none;
  } */

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
    }
  }
   /* .cart-secondary-typography{
    display: none;
   } */
  .cart-drawer__dialog {
    overflow: hidden;
    background: #fff !important;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__summary {
    background-color: var(--color-background);
    position: sticky;
    bottom: 0;
    z-index: 1;
  }
    @media screen and (min-width: 749px) {
       .cart-drawer__dialog .cart-items__empty-button{
        font-size: 16px;
        line-height: 24px;
       }
    }
{% endstylesheet %}
