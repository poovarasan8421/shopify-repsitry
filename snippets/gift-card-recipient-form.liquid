{% endstylesheet %}
<style>
/* Basic visual / accessibility helpers (adjust to match your theme) */
.recipient-form__accordion {
  {% comment %} margin: 0; {% endcomment %}
   margin: 0 0 10px;
}

/* Make the trigger look/behave like a button but keep markup simple */
.recipient-form__send-to {
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  background: none;
  border: none;
  padding: 0;
  text-align: left;
  font: inherit;
  margin:0;
}

/* Icon visibility controlled by aria-expanded (JS updates this attribute) */
.recipient-form__send-to .plus-icon { display: inline-block; }
.recipient-form__send-to .minus-icon { display: none; }

/* When expanded -> show minus, hide plus */
.recipient-form__send-to[aria-expanded="true"] .plus-icon { display: none; }
.recipient-form__send-to[aria-expanded="true"] .minus-icon { display: inline-block; }

/* Accordion content container: start closed; transitions handled by JS too */
#recipient-form-wrapper-{{ block.id }} {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  transition: max-height 340ms ease, opacity 240ms ease;
}

/* Optional small style so children don't jump layout while animating */
#recipient-form-wrapper-{{ block.id }} .recipient-fields {
  box-sizing: border-box;
}

</style>